    @Override
    protected void initializeComponents() {
        String[] columns = {"ID", "Name", "Role", "Email", "Phone", "Username", "Action"};
        tableModel = new DefaultTableModel(columns, 0) {
            @Override
            public boolean isCellEditable(int row, int column) {
                return column == 6;
            }
        };
        staffTable = new JTable(tableModel);
        staffTable.setFont(new Font("Segoe UI", Font.PLAIN, 12));
        staffTable.setRowHeight(45);
        staffTable.setShowGrid(true);
        staffTable.setGridColor(new Color(230, 230, 230));
        staffTable.setSelectionBackground(new Color(237, 243, 254)); // Light blue selection
        staffTable.setSelectionForeground(Color.BLACK);
        staffTable.setFocusable(false);
        
        // Table header with exact color (246,243,244) - no hover effect
        JTableHeader header = staffTable.getTableHeader();
        header.setFont(new Font("Segoe UI", Font.BOLD, 12));
        header.setBackground(new Color(246, 243, 244));
        header.setForeground(Color.BLACK);
        header.setReorderingAllowed(false);
        header.setPreferredSize(new Dimension(header.getWidth(), 40));
        header.setBorder(BorderFactory.createMatteBorder(0, 0, 2, 0, NAVY_BLUE));
        
        // Disable header hover effect
        header.setOpaque(true);
        
        // Set column widths - wider action column for buttons
        staffTable.getColumnModel().getColumn(0).setPreferredWidth(60);
        staffTable.getColumnModel().getColumn(1).setPreferredWidth(160);
        staffTable.getColumnModel().getColumn(2).setPreferredWidth(110);
        staffTable.getColumnModel().getColumn(3).setPreferredWidth(190);
        staffTable.getColumnModel().getColumn(4).setPreferredWidth(130);
        staffTable.getColumnModel().getColumn(5).setPreferredWidth(110);
        staffTable.getColumnModel().getColumn(6).setPreferredWidth(180);
        
        // Center align ID and Role columns
        DefaultTableCellRenderer centerRenderer = new DefaultTableCellRenderer();
        centerRenderer.setHorizontalAlignment(JLabel.CENTER);
        staffTable.getColumnModel().getColumn(0).setCellRenderer(centerRenderer);
        staffTable.getColumnModel().getColumn(2).setCellRenderer(centerRenderer);
        
        // Action column with buttons
        staffTable.getColumnModel().getColumn(6).setCellRenderer(new ActionCellRenderer());
        staffTable.getColumnModel().getColumn(6).setCellEditor(new ActionCellEditor());
    }
    
    @Override
    protected void setupLayout() {
        JPanel mainPanel = new JPanel(new BorderLayout());
        mainPanel.setBackground(PANEL_BG);
        
        // Header
        JPanel headerPanel = new JPanel(new BorderLayout());
        headerPanel.setBackground(PANEL_BG);
        headerPanel.setBorder(BorderFactory.createEmptyBorder(0, 0, 15, 0));
        
        JLabel titleLabel = new JLabel("Staff Management");
        titleLabel.setFont(new Font("Segoe UI", Font.BOLD, 22));
        titleLabel.setForeground(NAVY_BLUE);
        headerPanel.add(titleLabel, BorderLayout.WEST);
        
        JButton addButton = createNavyButton("+ ADD STAFF");
        addButton.addActionListener(e -> openRegistrationFrame());
        headerPanel.add(addButton, BorderLayout.EAST);
        
        mainPanel.add(headerPanel, BorderLayout.NORTH);
        
        // Table with black outer border (thin)
        JPanel tablePanel = new JPanel(new BorderLayout());
        tablePanel.setBackground(Color.WHITE);
        tablePanel.setBorder(BorderFactory.createLineBorder(Color.BLACK, 1));
        
        JScrollPane scrollPane = new JScrollPane(staffTable);
        scrollPane.setVerticalScrollBarPolicy(JScrollPane.VERTICAL_SCROLLBAR_AS_NEEDED);
        scrollPane.setBorder(BorderFactory.createEmptyBorder());
        scrollPane.getViewport().setBackground(Color.WHITE);
        tablePanel.add(scrollPane, BorderLayout.CENTER);
        
        mainPanel.add(tablePanel, BorderLayout.CENTER);
        
        add(mainPanel);
    }
    
    private JButton createNavyButton(String text) {
        JButton button = new JButton(text);
        button.setFont(new Font("Segoe UI", Font.BOLD, 11));
        button.setBackground(NAVY_BLUE);
        button.setForeground(Color.WHITE);
        button.setFocusPainted(false);
        button.setBorderPainted(false);
        button.setOpaque(true);
        button.setContentAreaFilled(true);
        button.setCursor(new Cursor(Cursor.HAND_CURSOR));
        button.setBorder(BorderFactory.createEmptyBorder(8, 15, 8, 15));
        
        // Hover effect
        button.addMouseListener(new MouseAdapter() {
            @Override
            public void mouseEntered(MouseEvent e) {
                button.setBackground(new Color(0, 0, 100));
            }
            
            @Override
            public void mouseExited(MouseEvent e) {
                button.setBackground(NAVY_BLUE);
            }
        });
        
        return button;
    }
    
    private void loadStaffData() {
        tableModel.setRowCount(0);
        List<User> allUsers = userDAO.readAll();
        
        for (User user : allUsers) {
            if (user.getRole() != UserRole.CUSTOMER) {
                Object[] row = {
                    user.getId(),
                    user.getFullName(),
                    user.getRoleDisplayName(),
                    user.getEmail(),
                    user.getPhone(),
                    user.getUsername(),
                    user
                };
                tableModel.addRow(row);
            }
        }
    }
    
    private void openRegistrationFrame() {
        RegistrationFrame regFrame = new RegistrationFrame();
        regFrame.addWindowListener(new java.awt.event.WindowAdapter() {
            @Override
            public void windowClosed(java.awt.event.WindowEvent e) {
                loadStaffData();
            }
        });
        regFrame.setVisible(true);
    }
    
    private void showEditStaffDialog(User user) {
        JDialog dialog = new JDialog((Frame) SwingUtilities.getWindowAncestor(this), "Edit Staff Information", true);
        dialog.setSize(550, 650);
        dialog.setLocationRelativeTo(this);
        dialog.setLayout(new BorderLayout());
        
        // Header panel with icon
        JPanel dialogHeader = new JPanel(new BorderLayout());
        dialogHeader.setBackground(NAVY_BLUE);
        dialogHeader.setBorder(BorderFactory.createEmptyBorder(20, 25, 20, 25));
        
        JLabel headerIcon = new JLabel("✎");
        headerIcon.setFont(new Font("Segoe UI", Font.BOLD, 24));
        headerIcon.setForeground(Color.WHITE);
        
        JLabel headerTitle = new JLabel(" Edit Staff Information");
        headerTitle.setFont(new Font("Segoe UI", Font.BOLD, 18));
        headerTitle.setForeground(Color.WHITE);
        
        JPanel headerLeftPanel = new JPanel(new FlowLayout(FlowLayout.LEFT, 5, 0));
        headerLeftPanel.setBackground(NAVY_BLUE);
        headerLeftPanel.add(headerIcon);
        headerLeftPanel.add(headerTitle);
        
        dialogHeader.add(headerLeftPanel, BorderLayout.WEST);
        dialog.add(dialogHeader, BorderLayout.NORTH);
        
        // Form panel with GridBagLayout - labels above fields
        JPanel formPanel = new JPanel(new GridBagLayout());
        formPanel.setBackground(Color.WHITE);
        formPanel.setBorder(BorderFactory.createEmptyBorder(30, 40, 30, 40));
        
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.fill = GridBagConstraints.HORIZONTAL;
        gbc.insets = new Insets(5, 5, 10, 5);
        
        // Full Name
        gbc.gridx = 0; gbc.gridy = 0;
        gbc.gridwidth = 1;
        formPanel.add(createLabelWithIcon("👤", "Full Name"), gbc);
        
        gbc.gridx = 0; gbc.gridy = 1;
        gbc.gridwidth = 2;
        JTextField nameField = new JTextField(user.getFullName(), 25);
        styleFormField(nameField);
        formPanel.add(nameField, gbc);
        
        // Email
        gbc.gridx = 0; gbc.gridy = 2;
        gbc.gridwidth = 1;
        formPanel.add(createLabelWithIcon("📧", "Email"), gbc);
        
        gbc.gridx = 0; gbc.gridy = 3;
        gbc.gridwidth = 2;
        JTextField emailField = new JTextField(user.getEmail(), 25);
        styleFormField(emailField);
        formPanel.add(emailField, gbc);
        
        // Phone
        gbc.gridx = 0; gbc.gridy = 4;
        gbc.gridwidth = 1;
        formPanel.add(createLabelWithIcon("📞", "Phone"), gbc);
        
        gbc.gridx = 0; gbc.gridy = 5;
        gbc.gridwidth = 2;
        JTextField phoneField = new JTextField(user.getPhone(), 25);
        styleFormField(phoneField);
        formPanel.add(phoneField, gbc);
        
        // Username (read-only)
        gbc.gridx = 0; gbc.gridy = 6;
        gbc.gridwidth = 1;
        formPanel.add(createLabelWithIcon("🔑", "Username"), gbc);
        
        gbc.gridx = 0; gbc.gridy = 7;
        gbc.gridwidth = 2;
        JTextField usernameField = new JTextField(user.getUsername(), 25);
        usernameField.setEditable(false);
        usernameField.setBackground(new Color(248, 248, 248));
        styleFormField(usernameField);
        formPanel.add(usernameField, gbc);
        
        // Password
        gbc.gridx = 0; gbc.gridy = 8;
        gbc.gridwidth = 1;
        formPanel.add(createLabelWithIcon("🔒", "Password"), gbc);
        
        gbc.gridx = 0; gbc.gridy = 9;
        gbc.gridwidth = 2;
        JPasswordField passwordField = new JPasswordField(user.getPassword(), 25);
        styleFormField(passwordField);
        formPanel.add(passwordField, gbc);
        
        // Role
        gbc.gridx = 0; gbc.gridy = 10;
        gbc.gridwidth = 1;
        formPanel.add(createLabelWithIcon("⭐", "Role"), gbc);
        
        gbc.gridx = 0; gbc.gridy = 11;
        gbc.gridwidth = 2;
        JComboBox<String> roleCombo = new JComboBox<>(new String[]{"MANAGER", "COUNTER STAFF", "TECHNICIAN"});
        String roleDisplay = user.getRoleDisplayName();
        if (roleDisplay.equals("Manager")) roleCombo.setSelectedItem("MANAGER");
        else if (roleDisplay.equals("Counter Staff")) roleCombo.setSelectedItem("COUNTER STAFF");
        else if (roleDisplay.equals("Technician")) roleCombo.setSelectedItem("TECHNICIAN");
        styleComboBoxField(roleCombo);
        formPanel.add(roleCombo, gbc);
        
        dialog.add(formPanel, BorderLayout.CENTER);
        
        // Button panel
        JPanel buttonPanel = new JPanel(new FlowLayout(FlowLayout.RIGHT, 15, 20));
        buttonPanel.setBackground(Color.WHITE);
        buttonPanel.setBorder(BorderFactory.createMatteBorder(1, 0, 0, 0, new Color(230, 230, 230)));
        
        JButton updateButton = createDialogButton("✓ UPDATE", new Color(34, 197, 94));
        updateButton.addActionListener(e -> {
            String name = nameField.getText().trim();
            String email = emailField.getText().trim();
            String phone = phoneField.getText().trim();
            String password = new String(passwordField.getPassword());
            String role = (String) roleCombo.getSelectedItem();
            
            if (name.isEmpty()) {
                JOptionPane.showMessageDialog(dialog, "Please enter full name.", "Validation Error", JOptionPane.WARNING_MESSAGE);
                return;
            }
            if (password.isEmpty()) {
                JOptionPane.showMessageDialog(dialog, "Please enter password.", "Validation Error", JOptionPane.WARNING_MESSAGE);
                return;
            }
            
            user.setFullName(name);
            user.setEmail(email);
            user.setPhone(phone);
            user.setPassword(password);
            
            // Convert display name back to enum
            if (role.equals("MANAGER")) user.setRole(UserRole.MANAGER);
            else if (role.equals("COUNTER STAFF")) user.setRole(UserRole.COUNTER_STAFF);
            else if (role.equals("TECHNICIAN")) user.setRole(UserRole.TECHNICIAN);
            
            userDAO.update(user);
            loadStaffData();
            dialog.dispose();
            
            JOptionPane.showMessageDialog(this, "✓ Staff updated successfully!", "Success", JOptionPane.INFORMATION_MESSAGE);
        });
        
        JButton cancelButton = createDialogButton("✗ CANCEL", new Color(100, 100, 100));
        cancelButton.addActionListener(e -> dialog.dispose());
        
        buttonPanel.add(updateButton);
        buttonPanel.add(cancelButton);
        dialog.add(buttonPanel, BorderLayout.SOUTH);
        
        dialog.setVisible(true);
    }
    
    private JPanel createLabelWithIcon(String icon, String text) {
        JPanel panel = new JPanel(new FlowLayout(FlowLayout.LEFT, 8, 0));
        panel.setBackground(Color.WHITE);
        
        JLabel iconLabel = new JLabel(icon);
        iconLabel.setFont(new Font("Segoe UI", Font.PLAIN, 16));
        
        JLabel textLabel = new JLabel(text);
        textLabel.setFont(new Font("Segoe UI", Font.BOLD, 13));
        textLabel.setForeground(new Color(60, 60, 60));
        
        panel.add(iconLabel);
        panel.add(textLabel);
        
        return panel;
    }
    
    private void styleFormField(JTextField field) {
        field.setFont(new Font("Segoe UI", Font.PLAIN, 13));
        field.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(new Color(200, 200, 200), 1),
            BorderFactory.createEmptyBorder(10, 12, 10, 12)
        ));
        field.setPreferredSize(new Dimension(350, 40));
        field.setMaximumSize(new Dimension(350, 40));
    }
    
    private void styleComboBoxField(JComboBox<String> combo) {
        combo.setFont(new Font("Segoe UI", Font.PLAIN, 13));
        combo.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(new Color(200, 200, 200), 1),
            BorderFactory.createEmptyBorder(10, 12, 10, 12)
        ));
        combo.setPreferredSize(new Dimension(350, 40));
        combo.setMaximumSize(new Dimension(350, 40));
    }
    
    private JButton createDialogButton(String text, Color color) {
        JButton button = new JButton(text);
        button.setFont(new Font("Segoe UI", Font.BOLD, 12));
        button.setBackground(color);
        button.setForeground(Color.WHITE);
        button.setFocusPainted(false);
        button.setBorderPainted(false);
        button.setOpaque(true);
        button.setCursor(new Cursor(Cursor.HAND_CURSOR));
        button.setBorder(BorderFactory.createEmptyBorder(10, 25, 10, 25));
        
        // Hover effect
        button.addMouseListener(new MouseAdapter() {
            @Override
            public void mouseEntered(MouseEvent e) {
                button.setBackground(color.darker());
            }
            
            @Override
            public void mouseExited(MouseEvent e) {
                button.setBackground(color);
            }
        });
        
        return button;
    }
    
    private JLabel createLabel(String text) {
        JLabel label = new JLabel(text);
        label.setFont(new Font("Segoe UI", Font.PLAIN, 12));
        return label;
    }
    
    private void deleteStaff(User user) {
        int confirm = JOptionPane.showConfirmDialog(this,
            "Are you sure you want to delete " + user.getFullName() + "?\nThis action cannot be undone.",
            "Confirm Delete",
            JOptionPane.YES_NO_OPTION,
            JOptionPane.WARNING_MESSAGE);
        
        if (confirm == JOptionPane.YES_OPTION) {
            userDAO.delete(user.getId());
            loadStaffData();
            JOptionPane.showMessageDialog(this, "✓ Staff deleted successfully!", "Success", JOptionPane.INFORMATION_MESSAGE);
        }
    }
    
