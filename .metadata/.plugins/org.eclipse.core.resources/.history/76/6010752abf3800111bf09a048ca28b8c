    private JPanel createInsetPanel(JComponent field, int width, int height) {
        JPanel panel = new JPanel(new BorderLayout());
        panel.setBackground(Color.WHITE);
        panel.setMaximumSize(new Dimension(width, height));
        panel.setPreferredSize(new Dimension(width, height));
        panel.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(BORDER_DARK, 2),
            BorderFactory.createLineBorder(BORDER_LIGHT, 2)
        ));
        
        field.setBorder(BorderFactory.createEmptyBorder(8, 12, 8, 12));
        panel.add(field, BorderLayout.CENTER);
        return panel;
    }
    
    private JPanel createOutsetPanel(JComponent button, int width, int height) {
        JPanel panel = new JPanel(new BorderLayout());
        panel.setBackground(NAVY_BLUE);
        panel.setMaximumSize(new Dimension(width, height));
        panel.setPreferredSize(new Dimension(width, height));
        panel.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(BORDER_LIGHT, 2),
            BorderFactory.createLineBorder(BORDER_DARK, 2)
        ));
        panel.add(button, BorderLayout.CENTER);
        return panel;
    }
    
    private JButton createDemoButton(String text, String username) {
        JButton btn = new JButton(text);
        btn.setFont(new Font("Segoe UI", Font.BOLD, 12));  // Updated font size
        btn.setPreferredSize(new Dimension(170, 45));      // Added preferred size
        btn.setFocusPainted(false);
        btn.setBackground(new Color(240, 240, 240));
        btn.setForeground(Color.BLACK);
        btn.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(BORDER_LIGHT, 1),
            BorderFactory.createLineBorder(BORDER_DARK, 1)
        ));
        btn.setCursor(new Cursor(Cursor.HAND_CURSOR));
        btn.addActionListener(e -> {
            usernameField.setText(username);
            passwordField.setText("password");
        });
        
        btn.addMouseListener(new MouseAdapter() {
            @Override
            public void mouseEntered(MouseEvent e) {
                btn.setBackground(new Color(230, 230, 230));
            }
            
            @Override
            public void mouseExited(MouseEvent e) {
                btn.setBackground(new Color(245, 245, 245));
            }
            
            @Override
            public void mousePressed(MouseEvent e) {
                btn.setBorder(BorderFactory.createCompoundBorder(
                    BorderFactory.createLineBorder(BORDER_DARK, 1),
                    BorderFactory.createLineBorder(BORDER_LIGHT, 1)
                ));
            }
            
            @Override
            public void mouseReleased(MouseEvent e) {
                btn.setBorder(BorderFactory.createCompoundBorder(
                    BorderFactory.createLineBorder(BORDER_LIGHT, 1),
                    BorderFactory.createLineBorder(BORDER_DARK, 1)
                ));
            }
        });
        
        return btn;
    }
    
    @Override
    protected void addEventHandlers() {
        passwordField.addActionListener(e -> handleLogin());
    }
    
    private void handleLogin() {
        String username = usernameField.getText().trim();
        String password = new String(passwordField.getPassword());
        
        if (username.isEmpty() || password.isEmpty()) {
            JOptionPane.showMessageDialog(this, 
                "Please enter username and password.", 
                "Login Error", 
                JOptionPane.ERROR_MESSAGE);
            return;
        }
        
        try {
            User user = authService.login(username, password);
            
            // Create and show dashboard on EDT
            SwingUtilities.invokeLater(() -> {
                DashboardFrame dashboard = new DashboardFrame(user);
                dashboard.setVisible(true);
            });
            
            // Dispose login frame
            this.dispose();
            
        } catch (Exception e) {
            JOptionPane.showMessageDialog(this, 
                "Invalid credentials. Please try again.", 
                "Login Error", 
                JOptionPane.ERROR_MESSAGE);
        }
    }
    
    // ===== CUSTOM CAR LOGO PANEL (slightly bigger, no cutoff) =====
    private class CarLogoPanel extends JPanel {
        public CarLogoPanel() {
            setOpaque(false);
        }
        
        @Override
        protected void paintComponent(Graphics g) {
            super.paintComponent(g);
            Graphics2D g2d = (Graphics2D) g;
            g2d.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
            
            int width = getWidth();
            int height = getHeight();
            
            // Yellow background
            g2d.setColor(YELLOW);
            g2d.fill(new RoundRectangle2D.Double(3, 3, width - 6, height - 6, 10, 10));
            
            // Border
            g2d.setColor(Color.BLACK);
            g2d.setStroke(new BasicStroke(2f));
            g2d.draw(new RoundRectangle2D.Double(3, 3, width - 6, height - 6, 10, 10));
            
            // Car body 
            g2d.setColor(NAVY_BLUE);
            g2d.fillRoundRect(18, height/2 - 3, 32, 14, 6, 6);
            
            // Car top
            g2d.fillRoundRect(24, height/2 - 10, 18, 10, 4, 4);
            
            // Windows
            g2d.setColor(new Color(200, 220, 255));
            g2d.fillRoundRect(26, height/2 - 8, 6, 6, 2, 2);
            g2d.fillRoundRect(34, height/2 - 8, 5, 6, 2, 2);
            
            // Wheels
            g2d.setColor(Color.BLACK);
            g2d.fillOval(17, height/2 + 7, 8, 8);
            g2d.fillOval(39, height/2 + 7, 8, 8);
            
            // Wheel hubs
            g2d.setColor(Color.LIGHT_GRAY);
            g2d.fillOval(23, height/2 + 9, 4, 4);
            g2d.fillOval(41, height/2 + 9, 4, 4);
            
            // Headlight
            g2d.setColor(YELLOW);
            g2d.fillOval(47, height/2 + 1, 4, 4);
            
            // Taillight
            g2d.setColor(Color.RED);
            g2d.fillOval(16, height/2 + 1, 4, 4);
        }
    }
