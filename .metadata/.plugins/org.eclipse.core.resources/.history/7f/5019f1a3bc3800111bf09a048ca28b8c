package ui.common;

import models.User;
import javax.swing.*;
import java.awt.*;
import java.awt.geom.RoundRectangle2D;

public class HeaderPanel extends JPanel {
    
    private static final long serialVersionUID = 1L;
    
    private User currentUser;
    private Color NAVY_BLUE = new Color(0, 0, 128);
    private Color YELLOW = new Color(252, 202, 12);
    
    public HeaderPanel(User user) {
        this.currentUser = user;
        setBackground(NAVY_BLUE);
        setBorder(BorderFactory.createMatteBorder(0, 0, 2, 0, Color.BLACK));
        setLayout(new GridBagLayout());
        setPreferredSize(new Dimension(0, 75));
        
        initializeComponents();
    }
    
    private void initializeComponents() {
        // Use GridBagLayout to center vertically
        setLayout(new GridBagLayout());
        
        // Main content panel
        JPanel contentPanel = new JPanel();
        contentPanel.setLayout(new BoxLayout(contentPanel, BoxLayout.X_AXIS));
        contentPanel.setOpaque(false);
        
        // Car logo
        CarLogoPanel carLogo = new CarLogoPanel();
        carLogo.setPreferredSize(new Dimension(50, 50));
        carLogo.setMinimumSize(new Dimension(50, 50));
        carLogo.setMaximumSize(new Dimension(50, 50));
        contentPanel.add(carLogo);
        contentPanel.add(Box.createHorizontalStrut(15));
        
        // Title and welcome panel
        JPanel textPanel = new JPanel();
        textPanel.setLayout(new BoxLayout(textPanel, BoxLayout.Y_AXIS));
        textPanel.setOpaque(false);
        
        JLabel titleLabel = new JLabel("APU-ASC SUPPORT SYSTEM");
        titleLabel.setFont(new Font("Segoe UI", Font.BOLD, 20));
        titleLabel.setForeground(Color.WHITE);
        titleLabel.setAlignmentX(Component.LEFT_ALIGNMENT);
        textPanel.add(titleLabel);
        
        textPanel.add(Box.createVerticalStrut(2));
        
        // Welcome panel
        JPanel welcomePanel = new JPanel();
        welcomePanel.setLayout(new BoxLayout(welcomePanel, BoxLayout.X_AXIS));
        welcomePanel.setOpaque(false);
        welcomePanel.setAlignmentX(Component.LEFT_ALIGNMENT);
        
        JLabel welcomeLabel = new JLabel("Welcome, ");
        welcomeLabel.setFont(new Font("Segoe UI", Font.PLAIN, 13));
        welcomeLabel.setForeground(Color.WHITE);
        welcomePanel.add(welcomeLabel);
        
        JLabel nameLabel = new JLabel(currentUser.getFullName());
        nameLabel.setFont(new Font("Segoe UI", Font.BOLD, 13));
        nameLabel.setForeground(Color.WHITE);
        welcomePanel.add(nameLabel);
        
        JLabel roleLabel = new JLabel(" (" + currentUser.getRoleDisplayName() + ")");
        roleLabel.setFont(new Font("Segoe UI", Font.PLAIN, 11));
        roleLabel.setForeground(YELLOW);
        welcomePanel.add(roleLabel);
        
        textPanel.add(welcomePanel);
        contentPanel.add(textPanel);
        
        // Left-align the content panel within the GridBagLayout
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.gridx = 0;
        gbc.gridy = 0;
        gbc.weightx = 1.0;
        gbc.weighty = 1.0;
        gbc.fill = GridBagConstraints.BOTH;
        gbc.anchor = GridBagConstraints.WEST;
        
        // Create a wrapper panel to hold the content with left padding
        JPanel wrapperPanel = new JPanel(new BorderLayout());
        wrapperPanel.setOpaque(false);
        wrapperPanel.add(contentPanel, BorderLayout.WEST);
        wrapperPanel.setBorder(BorderFactory.createEmptyBorder(0, 20, 0, 0));
        
        add(wrapperPanel, gbc);
    }
    
    // Car logo panel
    private class CarLogoPanel extends JPanel {
        
        private static final long serialVersionUID = 1L;
        
        public CarLogoPanel() {
            setOpaque(false);
        }
        
        @Override
        protected void paintComponent(Graphics g) {
            super.paintComponent(g);
            Graphics2D g2d = (Graphics2D) g;
            g2d.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
            
            int padding = 6; // space to prevent cutoff
            
            // Move drawing area inside (this replaces offsetX & offsetY)
            g2d.translate(padding, padding);
            
            int width = getWidth() - padding * 2;
            int height = getHeight() - padding * 2;
            
            // Shadow
            g2d.setColor(new Color(0, 0, 0, 30));
            g2d.fill(new RoundRectangle2D.Double(4, 6, width - 8, height - 8, 12, 12));
            
            // Yellow background
            g2d.setColor(YELLOW);
            g2d.fill(new RoundRectangle2D.Double(2, 2, width - 6, height - 6, 12, 12));
            
            // Border
            g2d.setColor(NAVY_BLUE);
            g2d.setStroke(new BasicStroke(2.5f));
            g2d.draw(new RoundRectangle2D.Double(2, 2, width - 6, height - 6, 12, 12));
            
            // Car body
            g2d.setColor(NAVY_BLUE);
            int carY = height / 2 - 2;
            g2d.fillRoundRect(14, carY, 30, 14, 8, 8);
            
            // Cabin
            GradientPaint cabinPaint = new GradientPaint(18, carY - 8, NAVY_BLUE, 30, carY - 8, new Color(0, 0, 180));
            g2d.setPaint(cabinPaint);
            g2d.fillRoundRect(20, carY - 8, 15, 10, 6, 6);
            
            // Windows
            g2d.setColor(new Color(180, 210, 255));
            g2d.fillRoundRect(23, carY - 6, 6, 6, 3, 3);
            g2d.fillRoundRect(31, carY - 6, 3, 6, 2, 2);
            
            // Shine
            g2d.setColor(new Color(255, 255, 255, 100));
            g2d.fillRoundRect(24, carY - 7, 3, 3, 1, 1);
            
            // Wheels
            g2d.setColor(Color.BLACK);
            g2d.fillOval(17, carY + 10, 9, 9);
            g2d.fillOval(34, carY + 10, 9, 9);
            
            // Rims
            g2d.setColor(new Color(80, 80, 80));
            g2d.fillOval(19, carY + 12, 5, 5);
            g2d.fillOval(36, carY + 12, 5, 5);
            
            // Hubs
            g2d.setColor(Color.LIGHT_GRAY);
            g2d.fillOval(20, carY + 13, 3, 3);
            g2d.fillOval(37, carY + 13, 3, 3);
            
            // Headlight
            g2d.setColor(new Color(255, 255, 200));
            g2d.fillOval(42, carY + 4, 4, 4);
            g2d.setColor(YELLOW);
            g2d.fillOval(43, carY + 5, 2, 2);
            
            // Taillight
            g2d.setColor(Color.RED);
            g2d.fillOval(11, carY + 4, 4, 4);
            
            // Ground line
            g2d.setColor(new Color(0, 0, 0, 50));
            g2d.setStroke(new BasicStroke(1.5f));
            g2d.drawLine(10, carY + 21, 52, carY + 21);
        }
    }
}