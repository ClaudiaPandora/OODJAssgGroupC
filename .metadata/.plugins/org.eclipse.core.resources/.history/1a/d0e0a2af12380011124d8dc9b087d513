package ui.common;

import enums.UserRole;
import models.User;
import javax.swing.*;
import java.awt.*;
import java.awt.event.ActionListener;
import java.awt.event.MouseAdapter;
import java.awt.event.MouseEvent;

public class NavigationPanel extends JPanel {
    
    private Color PANEL_BG = new Color(249, 249, 247);
    private Color NAVY_BLUE = new Color(0, 0, 128);
    private Color BORDER_DARK = new Color(176, 176, 176);
    private CardLayout cardLayout;
    private JPanel contentPanel;
    private JButton activeButton = null;
    
    public NavigationPanel(User user, CardLayout cardLayout, JPanel contentPanel) {
        this.cardLayout = cardLayout;
        this.contentPanel = contentPanel;
        
        setBackground(PANEL_BG);
        setBorder(BorderFactory.createMatteBorder(0, 0, 0, 1, BORDER_DARK));
        setLayout(new BoxLayout(this, BoxLayout.Y_AXIS));
        
        initializeComponents(user);
    }
    
    private void initializeComponents(User user) {
        add(Box.createVerticalStrut(20));
        
        // Main Menu Section
        add(createSectionLabel("MAIN MENU"));
        
        add(createNavButton("📊 Overview", "OVERVIEW", e -> showPanel("OVERVIEW")));
        
        if (user.getRole() == UserRole.MANAGER) {
            add(createNavButton("👥 Manage Staff", "STAFF", e -> showPanel("STAFF")));
            add(createNavButton("⚙ Set Prices", "PRICES", e -> showPanel("PRICES")));
            add(createNavButton("💬 Feedbacks & Comments", "FEEDBACKS", e -> showPanel("FEEDBACKS")));
            add(createNavButton("📈 Reports", "REPORTS", e -> showPanel("REPORTS")));
        } else if (user.getRole() == UserRole.COUNTER_STAFF) {
            add(createNavButton("👤 Manage Customers", "CUSTOMERS", e -> showPanel("CUSTOMERS")));
            add(createNavButton("📅 Appointments", "APPOINTMENTS", e -> showPanel("APPOINTMENTS")));
            add(createNavButton("💳 Payments", "PAYMENTS", e -> showPanel("PAYMENTS")));
        } else if (user.getRole() == UserRole.TECHNICIAN) {
            add(createNavButton("🔧 My Jobs", "JOBS", e -> showPanel("JOBS")));
        } else if (user.getRole() == UserRole.CUSTOMER) {
            add(createNavButton("📋 Service History", "HISTORY", e -> showPanel("HISTORY")));
            add(createNavButton("⭐ My Feedback", "MY_FEEDBACK", e -> showPanel("MY_FEEDBACK")));
        }
        
        add(Box.createVerticalStrut(30));
        
        // Account Section
        add(createSectionLabel("ACCOUNT"));
        add(createNavButton("👤 Profile", "PROFILE", e -> showPanel("PROFILE")));
        
        add(Box.createVerticalGlue());
        add(Box.createVerticalStrut(20));
    }
    
    private JLabel createSectionLabel(String text) {
        JLabel label = new JLabel(text);
        label.setFont(new Font("Tahoma", Font.BOLD, 11));
        label.setForeground(new Color(128, 128, 128));
        label.setBorder(BorderFactory.createEmptyBorder(10, 20, 5, 20));
        return label;
    }
    
    private JButton createNavButton(String text, String panelName, ActionListener action) {
        JButton button = new JButton(text);
        button.setFont(new Font("Tahoma", Font.PLAIN, 14));
        button.setHorizontalAlignment(SwingConstants.LEFT);
        button.setBorder(BorderFactory.createEmptyBorder(10, 25, 10, 25));
        button.setFocusPainted(false);
        button.setBackground(PANEL_BG);
        button.setForeground(Color.BLACK);
        button.setCursor(new Cursor(Cursor.HAND_CURSOR));
        
        button.addMouseListener(new MouseAdapter() {
            @Override
            public void mouseEntered(MouseEvent e) {
                if (activeButton != button) {
                    button.setBackground(new Color(230, 230, 230));
                }
            }
            
            @Override
            public void mouseExited(MouseEvent e) {
                if (activeButton != button) {
                    button.setBackground(PANEL_BG);
                }
            }
        });
        
        button.addActionListener(e -> {
            if (activeButton != null) {
                activeButton.setBackground(PANEL_BG);
                activeButton.setForeground(Color.BLACK);
            }
            button.setBackground(NAVY_BLUE);
            button.setForeground(Color.WHITE);
            activeButton = button;
            action.actionPerformed(e);
        });
        
        return button;
    }
    
    private void showPanel(String panelName) {
        cardLayout.show(contentPanel, panelName);
    }
}