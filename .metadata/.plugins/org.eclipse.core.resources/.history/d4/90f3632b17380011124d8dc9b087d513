package ui.manager;

import dao.AppointmentDAO;
import dao.FeedbackDAO;
import dao.CommentDAO;
import dao.UserDAO;
import models.Feedback;
import models.Comment;
import models.Appointment;
import models.User;
import ui.common.BasePanel;

import javax.swing.*;
import java.awt.*;
import java.util.List;

public class FeedbackPanel extends BasePanel {
    
    private FeedbackDAO feedbackDAO;
    private CommentDAO commentDAO;
    private AppointmentDAO appointmentDAO;
    private UserDAO userDAO;
    private JTextArea feedbackArea;
    private JTextArea commentArea;
    
    public FeedbackPanel() {
        this.feedbackDAO = new FeedbackDAO();
        this.commentDAO = new CommentDAO();
        this.appointmentDAO = new AppointmentDAO();
        this.userDAO = new UserDAO();
        
        setLayout(new BorderLayout());
        setBackground(PANEL_BG);
        setBorder(BorderFactory.createEmptyBorder(20, 20, 20, 20));
        
        initializeComponents();
        setupLayout();
        addEventHandlers();
        loadData();
    }
    
    @Override
    protected void initializeComponents() {
        feedbackArea = new JTextArea(15, 50);
        feedbackArea.setEditable(false);
        feedbackArea.setFont(new Font("Tahoma", Font.PLAIN, 12));
        
        commentArea = new JTextArea(15, 50);
        commentArea.setEditable(false);
        commentArea.setFont(new Font("Tahoma", Font.PLAIN, 12));
    }
    
    @Override
    protected void setupLayout() {
        JPanel mainPanel = new JPanel();
        mainPanel.setLayout(new BoxLayout(mainPanel, BoxLayout.Y_AXIS));
        mainPanel.setBackground(PANEL_BG);
        
        // Feedback Section
        JPanel feedbackSection = createSection("Technician Feedbacks");
        JScrollPane feedbackScroll = new JScrollPane(feedbackArea);
        feedbackScroll.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(BORDER_DARK, 2),
            BorderFactory.createLineBorder(BORDER_LIGHT, 2)
        ));
        feedbackSection.add(feedbackScroll, BorderLayout.CENTER);
        
        mainPanel.add(feedbackSection);
        mainPanel.add(Box.createVerticalStrut(20));
        
        // Comments Section
        JPanel commentSection = createSection("Customer Comments");
        JScrollPane commentScroll = new JScrollPane(commentArea);
        commentScroll.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(BORDER_DARK, 2),
            BorderFactory.createLineBorder(BORDER_LIGHT, 2)
        ));
        commentSection.add(commentScroll, BorderLayout.CENTER);
        
        mainPanel.add(commentSection);
        
        add(new JScrollPane(mainPanel));
    }
    
    private JPanel createSection(String title) {
        JPanel section = new JPanel(new BorderLayout());
        section.setBackground(PANEL_BG);
        section.setMaximumSize(new Dimension(800, 350));
        section.setAlignmentX(Component.LEFT_ALIGNMENT);
        
        JLabel titleLabel = new JLabel(title);
        titleLabel.setFont(new Font("Tahoma", Font.BOLD, 18));
        titleLabel.setForeground(NAVY_BLUE);
        titleLabel.setBorder(BorderFactory.createEmptyBorder(0, 0, 10, 0));
        section.add(titleLabel, BorderLayout.NORTH);
        
        return section;
    }
    
    private void loadData() {
        // Load feedbacks
        List<Feedback> feedbacks = feedbackDAO.readAll();
        StringBuilder feedbackText = new StringBuilder();
        
        for (Feedback f : feedbacks) {
            Appointment appt = appointmentDAO.findById(f.getAppointmentId());
            User tech = userDAO.findById(f.getTechnicianId());
            
            feedbackText.append("Job #").append(f.getAppointmentId()).append("\n");
            feedbackText.append("Technician: ").append(tech != null ? tech.getFullName() : "Unknown").append("\n");
            feedbackText.append("Feedback: ").append(f.getContent()).append("\n");
            feedbackText.append("-".repeat(50)).append("\n");
        }
        
        feedbackArea.setText(feedbackText.length() > 0 ? feedbackText.toString() : "No feedbacks available.");
        
        // Load comments
        List<Comment> comments = commentDAO.readAll();
        StringBuilder commentText = new StringBuilder();
        
        for (Comment c : comments) {
            Appointment appt = appointmentDAO.findById(c.getAppointmentId());
            User customer = userDAO.findById(c.getCustomerId());
            
            commentText.append("Appointment #").append(c.getAppointmentId()).append("\n");
            commentText.append("Customer: ").append(customer != null ? customer.getFullName() : "Unknown").append("\n");
            commentText.append("Comment: ").append(c.getContent()).append("\n");
            commentText.append("-".repeat(50)).append("\n");
        }
        
        commentArea.setText(commentText.length() > 0 ? commentText.toString() : "No comments available.");
    }
    
    @Override
    protected void addEventHandlers() {
        // Event handlers if needed
    }
}