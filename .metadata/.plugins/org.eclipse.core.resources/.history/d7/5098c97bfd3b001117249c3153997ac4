package ui.dashboard;

import dao.UserDAO;
import models.User;
import ui.common.BasePanel;

import javax.swing.*;
import java.awt.*;
import java.awt.geom.RoundRectangle2D;

public class ProfilePanel extends BasePanel {
    
    private User currentUser;
    private UserDAO userDAO;
    private JTextField fullNameField;
    private JTextField emailField;
    private JTextField phoneField;
    private JTextField usernameField;
    private JPasswordField passwordField;
    private JLabel nameLabel;
    
    public ProfilePanel(User user) {
        this.currentUser = user;
        this.userDAO = new UserDAO();
        setBackground(PANEL_BG);
        
        initializeComponents();
        setupLayout();
        addEventHandlers();
    }
    
    @Override
    protected void initializeComponents() {
        fullNameField = new JTextField(currentUser != null ? currentUser.getFullName() : "", 30);
        emailField = new JTextField(currentUser != null ? currentUser.getEmail() : "", 30);
        phoneField = new JTextField(currentUser != null ? currentUser.getPhone() : "", 30);
        usernameField = new JTextField(currentUser != null ? currentUser.getUsername() : "", 30);
        usernameField.setEditable(false);
        usernameField.setBackground(new Color(248, 248, 248));
        passwordField = new JPasswordField(currentUser != null ? currentUser.getPassword() : "", 30);
        
        styleTextField(fullNameField);
        styleTextField(emailField);
        styleTextField(phoneField);
        styleTextField(usernameField);
        stylePasswordField(passwordField);
    }
    
    private void styleTextField(JTextField field) {
        field.setFont(new Font("Segoe UI", Font.PLAIN, 13));
        field.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(new Color(200, 200, 200), 1),
            BorderFactory.createEmptyBorder(10, 12, 10, 12)
        ));
        field.setPreferredSize(new Dimension(300, 40));
    }
    
    private void stylePasswordField(JPasswordField field) {
        field.setFont(new Font("Segoe UI", Font.PLAIN, 13));
        field.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(new Color(200, 200, 200), 1),
            BorderFactory.createEmptyBorder(10, 12, 10, 12)
        ));
        field.setPreferredSize(new Dimension(300, 40));
    }
    
    @Override
    protected void setupLayout() {
        setLayout(new GridBagLayout());
        setBorder(BorderFactory.createEmptyBorder(20, 20, 20, 20));
        
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.gridx = 0;
        gbc.gridy = 0;
        gbc.weightx = 1.0;
        gbc.weighty = 1.0;
        
        JPanel profileCard = new JPanel();
        profileCard.setLayout(new BoxLayout(profileCard, BoxLayout.Y_AXIS));
        profileCard.setBackground(Color.WHITE);
        profileCard.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(BORDER_LIGHT, 2),
            BorderFactory.createLineBorder(BORDER_DARK, 2)
        ));
        profileCard.setMaximumSize(new Dimension(550, 520));
        profileCard.setPreferredSize(new Dimension(550, 520));
        
     // Banner (IMPROVED)
        JPanel bannerPanel = new JPanel();
        bannerPanel.setBackground(NAVY_BLUE);
        bannerPanel.setPreferredSize(new Dimension(550, 120));
        bannerPanel.setMaximumSize(new Dimension(Integer.MAX_VALUE, 120));
        bannerPanel.setLayout(new GridBagLayout()); // better centering

        // Avatar wrapper (centered)
        JPanel avatarWrapper = new JPanel();
        avatarWrapper.setOpaque(false);
        avatarWrapper.setLayout(new FlowLayout(FlowLayout.CENTER, 0, 0));

        // Circular Avatar Panel
        JPanel avatarPanel = new JPanel() {
            @Override
            protected void paintComponent(Graphics g) {
                super.paintComponent(g);
                Graphics2D g2d = (Graphics2D) g;

                g2d.setRenderingHint(RenderingHints.KEY_ANTIALIASING,
                                     RenderingHints.VALUE_ANTIALIAS_ON);

                int size = Math.min(getWidth(), getHeight());

                // shadow effect (NEW)
                g2d.setColor(new Color(0, 0, 0, 60));
                g2d.fillOval(3, 3, size - 6, size - 6);

                // white circle
                g2d.setColor(Color.WHITE);
                g2d.fillOval(0, 0, size - 6, size - 6);

                // border
                g2d.setColor(NAVY_BLUE.brighter());
                g2d.setStroke(new BasicStroke(3f));
                g2d.drawOval(0, 0, size - 6, size - 6);

                // initials
                g2d.setColor(NAVY_BLUE);
                g2d.setFont(new Font("Segoe UI", Font.BOLD, 26));

                String initials = getInitials(
                        currentUser != null ? currentUser.getFullName() : "User"
                );

                FontMetrics fm = g2d.getFontMetrics();
                int x = (size - fm.stringWidth(initials)) / 2;
                int y = (size + fm.getAscent()) / 2 - 4;

                g2d.drawString(initials, x, y);
            }
        };

        avatarPanel.setPreferredSize(new Dimension(85, 85));

        avatarWrapper.add(avatarPanel);
        bannerPanel.add(avatarWrapper);
        
        // Info Header
        JPanel infoHeader = new JPanel(new BorderLayout());
        infoHeader.setBackground(Color.WHITE);
        infoHeader.setBorder(BorderFactory.createEmptyBorder(50, 25, 15, 25));
        
        JPanel namePanel = new JPanel();
        namePanel.setLayout(new BoxLayout(namePanel, BoxLayout.Y_AXIS));
        namePanel.setBackground(Color.WHITE);
        namePanel.setAlignmentX(Component.LEFT_ALIGNMENT);
        
        nameLabel = new JLabel(currentUser != null ? currentUser.getFullName() : "User");
        nameLabel.setFont(new Font("Segoe UI", Font.BOLD, 22));
        nameLabel.setForeground(NAVY_BLUE);
        nameLabel.setAlignmentX(Component.LEFT_ALIGNMENT);
        namePanel.add(nameLabel);
        namePanel.add(Box.createVerticalStrut(6));
        
        JPanel metaPanel = new JPanel(new FlowLayout(FlowLayout.LEFT, 12, 0));
        metaPanel.setBackground(Color.WHITE);
        metaPanel.setAlignmentX(Component.LEFT_ALIGNMENT);
        
        // Role badge
        JLabel roleBadge = new JLabel(currentUser != null ? currentUser.getRoleDisplayName() : "");
        roleBadge.setFont(new Font("Segoe UI", Font.BOLD, 10));
        roleBadge.setForeground(NAVY_BLUE);
        roleBadge.setBackground(new Color(232, 242, 254));
        roleBadge.setOpaque(true);
        roleBadge.setBorder(BorderFactory.createEmptyBorder(3, 12, 3, 12));
        metaPanel.add(roleBadge);
        
        // ID label
        JLabel idLabel = new JLabel("ID: " + (currentUser != null ? currentUser.getId() : ""));
        idLabel.setFont(new Font("Segoe UI", Font.PLAIN, 10));
        idLabel.setForeground(new Color(120, 120, 120));
        metaPanel.add(idLabel);
        
        namePanel.add(metaPanel);
        infoHeader.add(namePanel, BorderLayout.WEST);
        
        profileCard.add(infoHeader);
        
        // Separator
        JSeparator separator = new JSeparator();
        separator.setForeground(new Color(230, 230, 230));
        profileCard.add(separator);
        
        // Form Panel
        JPanel formPanel = new JPanel(new GridBagLayout());
        formPanel.setBackground(Color.WHITE);
        formPanel.setBorder(BorderFactory.createEmptyBorder(20, 40, 20, 40));
        
        GridBagConstraints gbcForm = new GridBagConstraints();
        gbcForm.fill = GridBagConstraints.HORIZONTAL;
        gbcForm.insets = new Insets(8, 8, 8, 8);
        
        addFormField(formPanel, gbcForm, "Full Name", fullNameField, 0);
        addFormField(formPanel, gbcForm, "Email", emailField, 1);
        addFormField(formPanel, gbcForm, "Phone", phoneField, 2);
        addFormField(formPanel, gbcForm, "Username", usernameField, 3);
        addFormField(formPanel, gbcForm, "Password", passwordField, 4);
        
        profileCard.add(formPanel);
        
        // Button Panel
        JPanel buttonPanel = new JPanel(new FlowLayout(FlowLayout.CENTER, 0, 15));
        buttonPanel.setBackground(Color.WHITE);
        buttonPanel.setBorder(BorderFactory.createEmptyBorder(0, 30, 25, 30));
        
        JButton saveButton = createNavyButton("SAVE PROFILE CHANGES");
        saveButton.addActionListener(e -> saveProfile());
        
        buttonPanel.add(saveButton);
        profileCard.add(buttonPanel);
        
        gbc.anchor = GridBagConstraints.CENTER;
        add(profileCard, gbc);
    }
    
    private JButton createNavyButton(String text) {
        JButton button = new JButton(text);
        button.setFont(new Font("Segoe UI", Font.BOLD, 11));
        button.setBackground(NAVY_BLUE);
        button.setForeground(Color.WHITE);
        button.setFocusPainted(false);
        button.setBorderPainted(false);
        button.setOpaque(true);
        button.setContentAreaFilled(true);
        button.setCursor(new Cursor(Cursor.HAND_CURSOR));
        button.setBorder(BorderFactory.createEmptyBorder(10, 25, 10, 25));
        button.setPreferredSize(new Dimension(220, 40));
        
        button.addMouseListener(new java.awt.event.MouseAdapter() {
            public void mouseEntered(java.awt.event.MouseEvent e) {
                button.setBackground(new Color(0, 0, 100));
            }
            public void mouseExited(java.awt.event.MouseEvent e) {
                button.setBackground(NAVY_BLUE);
            }
        });
        
        return button;
    }
    
    private void addFormField(JPanel panel, GridBagConstraints gbc, String label, JComponent field, int row) {
        gbc.gridx = 0;
        gbc.gridy = row;
        gbc.weightx = 0;
        gbc.anchor = GridBagConstraints.WEST;
        JLabel fieldLabel = new JLabel(label);
        fieldLabel.setFont(new Font("Segoe UI", Font.BOLD, 11));
        fieldLabel.setForeground(new Color(80, 80, 80));
        fieldLabel.setPreferredSize(new Dimension(90, 30));
        panel.add(fieldLabel, gbc);
        
        gbc.gridx = 1;
        gbc.weightx = 1;
        gbc.anchor = GridBagConstraints.CENTER;
        panel.add(field, gbc);
    }
    
    private String getInitials(String fullName) {
        if (fullName == null || fullName.isEmpty()) return "U";
        String[] parts = fullName.split(" ");
        if (parts.length >= 2) {
            return (parts[0].charAt(0) + "" + parts[1].charAt(0)).toUpperCase();
        }
        return fullName.substring(0, Math.min(2, fullName.length())).toUpperCase();
    }
    
    private void saveProfile() {
        if (currentUser == null) return;
        
        String fullName = fullNameField.getText().trim();
        String email = emailField.getText().trim();
        String phone = phoneField.getText().trim();
        String password = new String(passwordField.getPassword());
        
        if (fullName.isEmpty()) {
            JOptionPane.showMessageDialog(this, "Full Name cannot be empty.", "Validation Error", JOptionPane.WARNING_MESSAGE);
            return;
        }
        
        if (password.isEmpty()) {
            JOptionPane.showMessageDialog(this, "Password cannot be empty.", "Validation Error", JOptionPane.WARNING_MESSAGE);
            return;
        }
        
        if (password.length() < 6) {
            JOptionPane.showMessageDialog(this, "Password must be at least 6 characters.", "Validation Error", JOptionPane.WARNING_MESSAGE);
            return;
        }
        
        if (!email.isEmpty() && !email.matches("^[A-Za-z0-9+_.-]+@(.+)$")) {
            JOptionPane.showMessageDialog(this, "Please enter a valid email address.", "Validation Error", JOptionPane.WARNING_MESSAGE);
            return;
        }
        
        if (!phone.isEmpty() && !phone.matches("\\d{10,12}")) {
            JOptionPane.showMessageDialog(this, "Please enter a valid phone number (10-12 digits).", "Validation Error", JOptionPane.WARNING_MESSAGE);
            return;
        }
        
        currentUser.setFullName(fullName);
        currentUser.setEmail(email);
        currentUser.setPhone(phone);
        currentUser.setPassword(password);
        
        boolean success = userDAO.update(currentUser);
        
        if (success) {
            nameLabel.setText(fullName);
            JOptionPane.showMessageDialog(this, "Profile updated successfully!", "Success", JOptionPane.INFORMATION_MESSAGE);
        } else {
            JOptionPane.showMessageDialog(this, "Failed to update profile.", "Error", JOptionPane.ERROR_MESSAGE);
        }
    }
    
    @Override
    protected void addEventHandlers() {
    }
}