    private JPanel createStatsPanel() {
        JPanel panel = new JPanel(new GridLayout(1, 4, 12, 0));
        panel.setBackground(PANEL_BG);
        panel.setMaximumSize(new Dimension(Integer.MAX_VALUE, 105));
        panel.setPreferredSize(new Dimension(0, 105));
        
        List<Appointment> allAppointments = appointmentDAO.readAll();
        String today = DateUtils.getCurrentDate();
        
        List<Appointment> todayAppointments = new ArrayList<>();
        for (Appointment a : allAppointments) {
            if (a.getDate() != null && a.getDate().equals(today)) {
                todayAppointments.add(a);
            }
        }
        
        int normalCount = 0, majorCount = 0, ongoingCount = 0, completedCount = 0;
        double revenue = 0;
        
        for (Appointment a : todayAppointments) {
            if (a.getServiceType() == ServiceType.NORMAL) normalCount++;
            else if (a.getServiceType() == ServiceType.MAJOR) majorCount++;
            if (a.getStatus() == AppointmentStatus.ASSIGNED) ongoingCount++;
            if (a.getStatus() == AppointmentStatus.COMPLETED || a.getStatus() == AppointmentStatus.PAID) completedCount++;
            if (a.getStatus() == AppointmentStatus.PAID) {
                revenue += a.getAmount() > 0 ? a.getAmount() : (a.getServiceType() == ServiceType.NORMAL ? 100 : 300);
            }
        }
        
        panel.add(createStatCard("Appointments Today", String.valueOf(todayAppointments.size()), 
            normalCount + " Normal • " + majorCount + " Major", new Color(59, 130, 246)));
        panel.add(createStatCard("Ongoing Services", String.valueOf(ongoingCount), null, new Color(234, 88, 12)));
        panel.add(createStatCard("Completed Today", String.valueOf(completedCount), null, new Color(34, 197, 94)));
        panel.add(createStatCard("Revenue Today", String.format("RM %.0f", revenue), null, new Color(168, 85, 247)));
        
        return panel;
    }
    
    private JPanel createStatCard(String label, String value, String subValue, Color accentColor) {
        JPanel card = new JPanel(new BorderLayout());
        card.setBackground(Color.WHITE);
        card.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(BORDER_LIGHT, 2),
            BorderFactory.createLineBorder(BORDER_DARK, 2)
        ));
        
        // Accent bar on left
        JPanel accentBar = new JPanel();
        accentBar.setBackground(accentColor);
        accentBar.setPreferredSize(new Dimension(4, 0));
        card.add(accentBar, BorderLayout.WEST);
        
        // Content
        JPanel content = new JPanel();
        content.setLayout(new BoxLayout(content, BoxLayout.Y_AXIS));
        content.setBackground(Color.WHITE);
        content.setBorder(BorderFactory.createEmptyBorder(12, 12, 12, 12));
        
        JLabel labelText = new JLabel(label);
        labelText.setFont(new Font("Segoe UI", Font.BOLD, 10));
        labelText.setForeground(new Color(120, 120, 120));
        labelText.setAlignmentX(Component.LEFT_ALIGNMENT);
        content.add(labelText);
        content.add(Box.createVerticalStrut(4));
        
        JLabel valueText = new JLabel(value);
        valueText.setFont(new Font("Segoe UI", Font.BOLD, 24));
        valueText.setForeground(Color.BLACK);
        valueText.setAlignmentX(Component.LEFT_ALIGNMENT);
        content.add(valueText);
        
        if (subValue != null) {
            content.add(Box.createVerticalStrut(2));
            JLabel subText = new JLabel(subValue);
            subText.setFont(new Font("Segoe UI", Font.PLAIN, 10));
            subText.setForeground(new Color(130, 130, 130));
            subText.setAlignmentX(Component.LEFT_ALIGNMENT);
            content.add(subText);
        }
        
        card.add(content, BorderLayout.CENTER);
        
        return card;
    }
    
    private JPanel createActivitiesPanel() {
        JPanel panel = new JPanel();
        panel.setLayout(new BoxLayout(panel, BoxLayout.Y_AXIS));
        panel.setBackground(Color.WHITE);
        panel.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(BORDER_LIGHT, 2),
            BorderFactory.createLineBorder(BORDER_DARK, 2)
        ));
        
        // Header
        JPanel headerPanel = new JPanel(new BorderLayout());
        headerPanel.setBackground(Color.WHITE);
        headerPanel.setBorder(BorderFactory.createEmptyBorder(12, 15, 8, 15));
        headerPanel.setMaximumSize(new Dimension(Integer.MAX_VALUE, 40));
        
        JLabel titleLabel = new JLabel("Recent Activities");
        titleLabel.setFont(new Font("Segoe UI", Font.BOLD, 13));
        titleLabel.setForeground(NAVY_BLUE);
        headerPanel.add(titleLabel, BorderLayout.WEST);
        
        JLabel liveLabel = new JLabel("LIVE UPDATES");
        liveLabel.setFont(new Font("Segoe UI", Font.BOLD, 9));
        liveLabel.setForeground(new Color(150, 150, 150));
        headerPanel.add(liveLabel, BorderLayout.EAST);
        
        panel.add(headerPanel);
        
        JSeparator separator = new JSeparator();
        separator.setMaximumSize(new Dimension(Integer.MAX_VALUE, 1));
        separator.setForeground(new Color(200, 200, 200));
        panel.add(separator);
        
        // Activity items
        List<Appointment> appointments = appointmentDAO.readAll();
        int count = 0;
        for (int i = appointments.size() - 1; i >= 0 && count < 6; i--, count++) {
            Appointment a = appointments.get(i);
            User customer = userDAO.findById(a.getCustomerId());
            
            JPanel item = new JPanel(new BorderLayout());
            item.setBackground(Color.WHITE);
            item.setBorder(BorderFactory.createEmptyBorder(4, 15, 4, 15));
            item.setPreferredSize(new Dimension(0, 30));
            item.setMaximumSize(new Dimension(Integer.MAX_VALUE, 30));
            
            JPanel leftPanel = new JPanel(new FlowLayout(FlowLayout.LEFT, 8, 0));
            leftPanel.setBackground(Color.WHITE);
            
            JLabel dotLabel = new JLabel("●");
            dotLabel.setFont(new Font("Segoe UI", Font.PLAIN, 8));
            
            Color dotColor;
            String actionText;
            if (a.getStatus() == AppointmentStatus.ASSIGNED) {
                dotColor = new Color(59, 130, 246);
                actionText = " assigned to ";
            } else if (a.getStatus() == AppointmentStatus.COMPLETED) {
                dotColor = new Color(34, 197, 94);
                actionText = " completed for ";
            } else if (a.getStatus() == AppointmentStatus.PAID) {
                dotColor = new Color(168, 85, 247);
                actionText = " paid for ";
            } else {
                dotColor = new Color(234, 179, 8);
                actionText = " booked for ";
            }
            dotLabel.setForeground(dotColor);
            leftPanel.add(dotLabel);
            
            String customerName = customer != null ? customer.getFullName() : "Customer";
            JLabel textLabel = new JLabel(customerName + actionText + a.getServiceType() + " service");
            textLabel.setFont(new Font("Segoe UI", Font.PLAIN, 11));
            textLabel.setForeground(new Color(60, 60, 60));
            leftPanel.add(textLabel);
            
            item.add(leftPanel, BorderLayout.WEST);
            
            JLabel timeLabel = new JLabel(a.getStartTime());
            timeLabel.setFont(new Font("Monospaced", Font.PLAIN, 10));
            timeLabel.setForeground(new Color(140, 140, 140));
            item.add(timeLabel, BorderLayout.EAST);
            
            panel.add(item);
            if (count < 5 && i > 0) {
                JSeparator itemSeparator = new JSeparator();
                itemSeparator.setMaximumSize(new Dimension(Integer.MAX_VALUE, 1));
                itemSeparator.setForeground(new Color(230, 230, 230));
                panel.add(itemSeparator);
            }
        }
        
        return panel;
    }
    
    private JPanel createRightPanel() {
        JPanel panel = new JPanel();
        panel.setLayout(new BoxLayout(panel, BoxLayout.Y_AXIS));
        panel.setBackground(PANEL_BG);
        
        // Technician Status
        JPanel techPanel = new JPanel();
        techPanel.setLayout(new BoxLayout(techPanel, BoxLayout.Y_AXIS));
        techPanel.setBackground(Color.WHITE);
        techPanel.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(BORDER_LIGHT, 2),
            BorderFactory.createLineBorder(BORDER_DARK, 2)
        ));
        
        JPanel techHeader = new JPanel(new BorderLayout());
        techHeader.setBackground(Color.WHITE);
        techHeader.setBorder(BorderFactory.createEmptyBorder(12, 15, 8, 15));
        techHeader.setMaximumSize(new Dimension(Integer.MAX_VALUE, 40));
        
        JLabel techTitle = new JLabel("Tech Status");
        techTitle.setFont(new Font("Segoe UI", Font.BOLD, 13));
        techTitle.setForeground(NAVY_BLUE);
        techHeader.add(techTitle, BorderLayout.WEST);
        
        List<Technician> techs = userDAO.readTechnicians();
        JLabel countLabel = new JLabel(techs.size() + " Active");
        countLabel.setFont(new Font("Segoe UI", Font.BOLD, 9));
        countLabel.setForeground(new Color(150, 150, 150));
        techHeader.add(countLabel, BorderLayout.EAST);
        
        techPanel.add(techHeader);
        
        JSeparator techSeparator = new JSeparator();
        techSeparator.setMaximumSize(new Dimension(Integer.MAX_VALUE, 1));
        techSeparator.setForeground(new Color(200, 200, 200));
        techPanel.add(techSeparator);
        
        List<Appointment> appointments = appointmentDAO.readAll();
        String today = DateUtils.getCurrentDate();
        
        for (int i = 0; i < techs.size(); i++) {
            Technician tech = techs.get(i);
            boolean isBusy = false;
            for (Appointment a : appointments) {
                if (tech.getId().equals(a.getTechnicianId()) && 
                    a.getStatus() == AppointmentStatus.ASSIGNED && 
                    today.equals(a.getDate())) {
                    isBusy = true;
                    break;
                }
            }
            
            JPanel techItem = new JPanel(new BorderLayout());
            techItem.setBackground(Color.WHITE);
            techItem.setBorder(BorderFactory.createEmptyBorder(10, 15, 10, 15));
            
            JPanel leftPanel = new JPanel(new FlowLayout(FlowLayout.LEFT, 10, 0));
            leftPanel.setBackground(Color.WHITE);
            
            // Circular avatar with initials
            JPanel avatar = createAvatar(tech.getFullName());
            leftPanel.add(avatar);
            
            JPanel namePanel = new JPanel();
            namePanel.setLayout(new BoxLayout(namePanel, BoxLayout.Y_AXIS));
            namePanel.setBackground(Color.WHITE);
            
            JLabel nameLabel = new JLabel(tech.getFullName());
            nameLabel.setFont(new Font("Segoe UI", Font.BOLD, 11));
            nameLabel.setForeground(new Color(40, 40, 40));
            namePanel.add(nameLabel);
            
            JLabel idLabel = new JLabel("ID: " + tech.getId());
            idLabel.setFont(new Font("Segoe UI", Font.PLAIN, 9));
            idLabel.setForeground(new Color(140, 140, 140));
            namePanel.add(idLabel);
            
            leftPanel.add(namePanel);
            techItem.add(leftPanel, BorderLayout.WEST);
            
            JLabel statusLabel = new JLabel(isBusy ? "BUSY" : "AVAILABLE");
            statusLabel.setFont(new Font("Segoe UI", Font.BOLD, 9));
            if (isBusy) {
                statusLabel.setForeground(new Color(234, 88, 12));
                statusLabel.setBackground(new Color(255, 237, 213));
            } else {
                statusLabel.setForeground(new Color(34, 197, 94));
                statusLabel.setBackground(new Color(220, 252, 231));
            }
            statusLabel.setOpaque(true);
            statusLabel.setBorder(BorderFactory.createEmptyBorder(4, 8, 4, 8));
            techItem.add(statusLabel, BorderLayout.EAST);
            
            techPanel.add(techItem);
            
            if (i < techs.size() - 1) {
                JSeparator itemSeparator = new JSeparator();
                itemSeparator.setMaximumSize(new Dimension(Integer.MAX_VALUE, 1));
                itemSeparator.setForeground(new Color(230, 230, 230));
                techPanel.add(itemSeparator);
            }
        }
        
        panel.add(techPanel);
        panel.add(Box.createVerticalStrut(12));
        
        // Feedback Highlights
        JPanel feedbackPanel = createFeedbackPanel();
        panel.add(feedbackPanel);
        
        return panel;
    }
    
    private JPanel createAvatar(String fullName) {
        String initials = getInitials(fullName);
        
        JPanel avatarPanel = new JPanel() {
            private static final long serialVersionUID = 1L;
            
            @Override
            protected void paintComponent(Graphics g) {
                super.paintComponent(g);
                Graphics2D g2d = (Graphics2D) g;
                g2d.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                
                int size = Math.min(getWidth(), getHeight());
                int x = (getWidth() - size) / 2;
                int y = (getHeight() - size) / 2;
                
                g2d.setColor(NAVY_BLUE);
                g2d.fillOval(x, y, size, size);
                
                g2d.setColor(Color.WHITE);
                g2d.setFont(new Font("Segoe UI", Font.BOLD, size / 2));
                FontMetrics fm = g2d.getFontMetrics();
                int textX = (getWidth() - fm.stringWidth(initials)) / 2;
                int textY = (getHeight() - fm.getHeight()) / 2 + fm.getAscent();
                g2d.drawString(initials, textX, textY);
            }
        };
        
        avatarPanel.setPreferredSize(new Dimension(32, 32));
        avatarPanel.setMinimumSize(new Dimension(32, 32));
        avatarPanel.setMaximumSize(new Dimension(32, 32));
        avatarPanel.setBackground(Color.WHITE);
        avatarPanel.setOpaque(false);
        
        return avatarPanel;
    }
    
    private String getInitials(String fullName) {
        if (fullName == null || fullName.isEmpty()) return "?";
        String[] parts = fullName.split(" ");
        if (parts.length >= 2) {
            return (parts[0].charAt(0) + "" + parts[1].charAt(0)).toUpperCase();
        }
        return fullName.substring(0, Math.min(2, fullName.length())).toUpperCase();
    }
    
    private JPanel createFeedbackPanel() {
        JPanel feedbackPanel = new JPanel();
        feedbackPanel.setLayout(new BoxLayout(feedbackPanel, BoxLayout.Y_AXIS));
        feedbackPanel.setBackground(Color.WHITE);
        feedbackPanel.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(BORDER_LIGHT, 2),
            BorderFactory.createLineBorder(BORDER_DARK, 2)
        ));

        // Header
        JPanel header = new JPanel(new BorderLayout());
        header.setBackground(Color.WHITE);
        header.setBorder(BorderFactory.createEmptyBorder(10, 15, 6, 15));
        header.setMaximumSize(new Dimension(Integer.MAX_VALUE, 35));

        JLabel title = new JLabel("Customer Feedback Highlights");
        title.setFont(new Font("Segoe UI", Font.BOLD, 13));
        title.setForeground(NAVY_BLUE);
        header.add(title, BorderLayout.WEST);

        feedbackPanel.add(header);

        // Divider
        JSeparator sep = new JSeparator();
        sep.setForeground(new Color(220, 220, 220));
        sep.setMaximumSize(new Dimension(Integer.MAX_VALUE, 1));
        feedbackPanel.add(sep);

        // Content
        JPanel content = new JPanel();
        content.setLayout(new BoxLayout(content, BoxLayout.Y_AXIS));
        content.setBackground(Color.WHITE);
        content.setBorder(BorderFactory.createEmptyBorder(15, 15, 15, 15));

        List<Feedback> feedbacks = feedbackDAO.readAll();

        if (feedbacks.isEmpty()) {
            JLabel emptyLabel = new JLabel("No feedback available yet");
            emptyLabel.setFont(new Font("Segoe UI", Font.PLAIN, 12));
            emptyLabel.setForeground(new Color(140, 140, 140));
            emptyLabel.setAlignmentX(Component.CENTER_ALIGNMENT);
            
            content.add(Box.createVerticalStrut(10));
            content.add(emptyLabel);
            content.add(Box.createVerticalStrut(10));
            
            feedbackPanel.add(content);
            return feedbackPanel;
        }

        // Get latest feedback only
        Feedback latest = feedbacks.get(feedbacks.size() - 1);

        // Rating with stars
        JPanel ratingPanel = new JPanel(new FlowLayout(FlowLayout.LEFT, 0, 0));
        ratingPanel.setBackground(Color.WHITE);
        ratingPanel.setAlignmentX(Component.LEFT_ALIGNMENT);

        for (int i = 0; i < 5; i++) {
            JLabel star = new JLabel(i < latest.getRating() ? "★" : "☆");
            star.setFont(new Font("Segoe UI", Font.PLAIN, 14));
            star.setForeground(i < latest.getRating() ? YELLOW : new Color(200, 200, 200));
            ratingPanel.add(star);
        }

        content.add(ratingPanel);
        content.add(Box.createVerticalStrut(8));

        // Comment
        String commentText = latest.getContent();
        if (commentText == null || commentText.trim().isEmpty()) {
            commentText = "No comment provided";
        }
        
        if (commentText.length() > 50) {
            commentText = commentText.substring(0, 47) + "...";
        }

        JLabel commentLabel = new JLabel("\"" + commentText + "\"");
        commentLabel.setFont(new Font("Segoe UI", Font.ITALIC, 11));
        commentLabel.setForeground(new Color(80, 80, 80));
        commentLabel.setAlignmentX(Component.LEFT_ALIGNMENT);
        content.add(commentLabel);

        feedbackPanel.add(content);
        return feedbackPanel;
    }
    
