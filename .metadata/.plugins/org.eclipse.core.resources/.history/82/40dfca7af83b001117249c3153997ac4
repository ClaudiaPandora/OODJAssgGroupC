        legend.setBackground(Color.WHITE);
        legend.add(createLegendItem("Normal", NAVY_BLUE));
        legend.add(createLegendItem("Major", YELLOW));

        panel.add(legend, BorderLayout.SOUTH);

        return panel;
    }

    private void drawServiceChart(JComponent c, Graphics g) {

        Graphics2D g2 = (Graphics2D) g;
        g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);

        List<Appointment> appts = appointmentDAO.readAll();

        long normal = appts.stream().filter(a -> a.getServiceType() == ServiceType.NORMAL).count();
        long major = appts.stream().filter(a -> a.getServiceType() == ServiceType.MAJOR).count();

        long total = normal + major;

        int w = c.getWidth();
        int h = c.getHeight();

        int padding = 40;

        int size = Math.min(w, h) / 3;
        if (size <= 0) return;

        int x = (w - size) / 2;
        int y = (h - size) / 2 - 10;
        
        if (total == 0) {
            g2.setColor(Color.LIGHT_GRAY);
            g2.fillOval(x, y, size, size);
            return;
        }

        int angleNormal = (int) (360.0 * normal / total);

        g2.setColor(NAVY_BLUE);
        g2.fillArc(x, y, size, size, 0, angleNormal);

        g2.setColor(YELLOW);
        g2.fillArc(x, y, size, size, angleNormal, 360 - angleNormal);

        // Optional center text (cleaner UI)
        g2.setColor(Color.BLACK);
        g2.setFont(new Font("Segoe UI", Font.BOLD, 12));
        String text = String.valueOf(total);

        FontMetrics fm = g2.getFontMetrics();
        g2.drawString(text, (w - fm.stringWidth(text)) / 2, h / 2);
    }    
    
