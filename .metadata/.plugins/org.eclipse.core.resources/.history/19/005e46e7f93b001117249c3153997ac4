    private void drawRevenueLineChart(Graphics g) {
        Graphics2D g2 = (Graphics2D) g;
        g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
        
        int w = g.getClipBounds().width;
        int h = g.getClipBounds().height;
        int[] revenues = {400, 300, 600, 800, 500, 900, 200};
        String[] days = {"Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"};
        
        int margin = 30;
        int chartW = w - 2 * margin;
        int chartH = h - 2 * margin;
        int maxRev = 1000;
        
        // Draw axes
        g2.setColor(Color.LIGHT_GRAY);
        g2.drawLine(margin, h - margin, w - margin, h - margin);
        g2.drawLine(margin, margin, margin, h - margin);
        
        // Draw line
        g2.setColor(NAVY_BLUE);
        g2.setStroke(new BasicStroke(2));
        
        int[] xPoints = new int[7];
        int[] yPoints = new int[7];
        
        for (int i = 0; i < 7; i++) {
            xPoints[i] = margin + i * chartW / 6;
            yPoints[i] = h - margin - (revenues[i] * chartH / maxRev);
        }
        
        g2.drawPolyline(xPoints, yPoints, 7);
        
        // Draw dots
        g2.setColor(YELLOW);
        for (int i = 0; i < 7; i++) {
            g2.fillOval(xPoints[i] - 4, yPoints[i] - 4, 8, 8);
            g2.setColor(NAVY_BLUE);
            g2.drawOval(xPoints[i] - 4, yPoints[i] - 4, 8, 8);
            g2.setColor(YELLOW);
        }
        
        // Labels
        g2.setColor(Color.BLACK);
        g2.setFont(new Font("Segoe UI", Font.PLAIN, 8));
        for (int i = 0; i < 7; i++) {
            g2.drawString(days[i], xPoints[i] - 10, h - margin + 15);
        }
    }
    
