    private void updateCategoryButtonStyle(String active) {
        JButton[] buttons = {allBtn, serviceBtn, revenueBtn, staffBtn, customerBtn, feedbackBtn};
        String[] texts = {"ALL", "SERVICE", "REVENUE", "STAFF", "CUSTOMER", "FEEDBACK"};
        for (int i = 0; i < buttons.length; i++) {
            if (texts[i].equals(active)) {
                buttons[i].setBackground(NAVY_BLUE);
                buttons[i].setForeground(Color.WHITE);
            } else {
                buttons[i].setBackground(Color.WHITE);
                buttons[i].setForeground(Color.BLACK);
            }
        }
    }
    
