    private void drawCustomerPieChart(Graphics g) {
        Graphics2D g2 = (Graphics2D) g;
        g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
        
        List<Customer> customers = userDAO.readCustomers();
        List<Appointment> appointments = appointmentDAO.readAll();
        long returning = customers.stream().filter(c -> appointments.stream()
            .filter(a -> a.getCustomerId().equals(c.getId())).count() > 1).count();
        long newCust = customers.size() - returning;
        long total = customers.size();
        
        int w = g.getClipBounds().width;
        int h = g.getClipBounds().height;
        int size = Math.min(w, h) - 20;
        int x = (w - size) / 2;
        int y = (h - size) / 2;
        
        if (total == 0) return;
        
        int angleNew = (int) (360.0 * newCust / total);
        
        g2.setColor(new Color(16, 185, 129));
        g2.fillArc(x, y, size, size, 0, angleNew);
        
        g2.setColor(new Color(59, 130, 246));
        g2.fillArc(x, y, size, size, angleNew, 360 - angleNew);
    }
    
    private JPanel createLoyaltyCard() {
