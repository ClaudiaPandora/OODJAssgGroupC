        content.setBorder(BorderFactory.createEmptyBorder(5, 15, 15, 15));
        
        List<Customer> customers = userDAO.readCustomers();
        List<Appointment> appointments = appointmentDAO.readAll();
        
        // Sort by visits
        customers.sort((c1, c2) -> {
            long v1 = appointments.stream().filter(a -> a.getCustomerId().equals(c1.getId())).count();
            long v2 = appointments.stream().filter(a -> a.getCustomerId().equals(c2.getId())).count();
