    private void drawTechnicianBarChart(Graphics g) {
        Graphics2D g2 = (Graphics2D) g;
        g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
        
        List<Technician> techs = userDAO.readTechnicians();
        List<Appointment> appointments = appointmentDAO.readAll();
        
        int w = g.getClipBounds().width;
        int h = g.getClipBounds().height;
        int margin = 30;
        int chartW = w - 2 * margin;
        int chartH = h - 2 * margin;
        
        // Find max completed
        long maxCompleted = 0;
        for (Technician t : techs) {
            long completed = appointments.stream()
                .filter(a -> t.getId().equals(a.getTechnicianId()) && 
                    (a.getStatus() == AppointmentStatus.COMPLETED || a.getStatus() == AppointmentStatus.PAID))
                .count();
            if (completed > maxCompleted) maxCompleted = completed;
        }
        if (maxCompleted == 0) maxCompleted = 1;
        
        int barWidth = chartW / (techs.size() * 2);
        int x = margin;
        
        for (Technician t : techs) {
            long completed = appointments.stream()
                .filter(a -> t.getId().equals(a.getTechnicianId()) && 
                    (a.getStatus() == AppointmentStatus.COMPLETED || a.getStatus() == AppointmentStatus.PAID))
                .count();
            
            int barHeight = (int) (completed * chartH / maxCompleted);
            
            g2.setColor(NAVY_BLUE);
            g2.fillRect(x, h - margin - barHeight, barWidth - 5, barHeight);
            
            g2.setColor(YELLOW);
            g2.fillRect(x + barWidth, h - margin - barHeight, barWidth - 5, barHeight);
            
            x += barWidth * 3;
        }
    }
    
