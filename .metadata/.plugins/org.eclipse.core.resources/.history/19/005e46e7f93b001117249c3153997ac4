        });
        
        long maxVisits = 0;
        if (!customers.isEmpty()) {
            maxVisits = appointments.stream().filter(a -> a.getCustomerId().equals(customers.get(0).getId())).count();
        }
        
        int count = 0;
        for (Customer c : customers) {
            long visits = appointments.stream().filter(a -> a.getCustomerId().equals(c.getId())).count();
            if (visits > 0 && count < 5) {
                JPanel row = new JPanel(new BorderLayout());
                row.setBackground(Color.WHITE);
                row.setBorder(BorderFactory.createEmptyBorder(5, 0, 5, 0));
                
                JPanel leftPanel = new JPanel(new FlowLayout(FlowLayout.LEFT, 5, 0));
                leftPanel.setBackground(Color.WHITE);
                
                JLabel rankLabel = new JLabel(String.valueOf(count + 1));
                rankLabel.setFont(new Font("Segoe UI", Font.BOLD, 10));
                rankLabel.setForeground(NAVY_BLUE);
                rankLabel.setPreferredSize(new Dimension(20, 20));
                leftPanel.add(rankLabel);
                
                JLabel nameLabel = new JLabel(c.getFullName());
                nameLabel.setFont(new Font("Segoe UI", Font.PLAIN, 11));
                leftPanel.add(nameLabel);
                
                row.add(leftPanel, BorderLayout.WEST);
                
                JLabel visitsLabel = new JLabel(visits + " visits");
                visitsLabel.setFont(new Font("Segoe UI", Font.BOLD, 10));
                visitsLabel.setForeground(NAVY_BLUE);
                row.add(visitsLabel, BorderLayout.EAST);
                
                content.add(row);
                
                // Progress bar
                JProgressBar bar = new JProgressBar(0, (int) maxVisits);
                bar.setValue((int) visits);
                bar.setForeground(YELLOW);
                bar.setBackground(new Color(240, 240, 240));
                bar.setPreferredSize(new Dimension(0, 4));
                content.add(bar);
                content.add(Box.createVerticalStrut(5));
                
                count++;
            }
        }
        
        card.add(content);
        return card;
    }
    
