    private void drawFeedbackBarChart(Graphics g) {
        Graphics2D g2 = (Graphics2D) g;
        g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
        
        List<Feedback> feedbacks = feedbackDAO.readAll();
        int[] ratings = new int[6];
        for (Feedback f : feedbacks) {
            int r = f.getRating();
            if (r >= 1 && r <= 5) ratings[r]++;
        }
        
        int maxCount = 1;
        for (int i = 1; i <= 5; i++) {
            if (ratings[i] > maxCount) maxCount = ratings[i];
        }
        
        int w = g.getClipBounds().width;
        int h = g.getClipBounds().height;
        int margin = 30;
        int chartW = w - 2 * margin;
        int chartH = h - 2 * margin;
        int barWidth = chartW / 6;
        
        for (int i = 1; i <= 5; i++) {
            int barHeight = ratings[i] * chartH / maxCount;
            int x = margin + i * barWidth;
            
            g2.setColor(YELLOW);
            g2.fillRect(x - barWidth/2, h - margin - barHeight, barWidth - 5, barHeight);
            g2.setColor(NAVY_BLUE);
            g2.drawRect(x - barWidth/2, h - margin - barHeight, barWidth - 5, barHeight);
            
            g2.setColor(Color.BLACK);
            g2.drawString(i + "★", x - 8, h - margin + 15);
        }
    }
    
