package ui.manager;

import dao.UserDAO;
import enums.UserRole;
import models.CounterStaff;
import models.Manager;
import models.Technician;
import models.User;

import javax.swing.*;
import java.awt.*;
import java.awt.event.MouseAdapter;
import java.awt.event.MouseEvent;

public class StaffFormPanel extends JDialog {
    
    protected JTextField fullNameField;
    protected JTextField emailField;
    protected JTextField phoneField;
    protected JTextField usernameField;
    protected JPasswordField passwordField;
    protected JComboBox<String> roleComboBox;
    protected UserDAO userDAO;
    protected User existingUser;
    protected String mode; // "REGISTER" or "EDIT"
    protected Runnable onSuccessCallback;
    
    // Colors
    protected Color NAVY_BLUE = new Color(0, 0, 128);
    protected Color YELLOW = new Color(252, 202, 12);
    protected Color BORDER_LIGHT = new Color(200, 200, 200);
    protected Color BORDER_DARK = new Color(100, 100, 100);
    
    public StaffFormPanel(Frame parent, String mode, User user, Runnable onSuccessCallback) {
        super(parent, true);
        this.userDAO = new UserDAO();
        this.mode = mode;
        this.existingUser = user;
        this.onSuccessCallback = onSuccessCallback;
        
        if ("EDIT".equals(mode)) {
            setTitle("Edit Staff");
        } else {
            setTitle("Register New Staff");
        }
        
        setSize(500, 560);
        setLocationRelativeTo(parent);
        setResizable(false);
        setDefaultCloseOperation(JDialog.DISPOSE_ON_CLOSE);
        
        initializeComponents();
        setupLayout();
        addEventHandlers();
        
        if ("EDIT".equals(mode) && existingUser != null) {
            populateFields();
        }
    }
    
    protected void initializeComponents() {
        fullNameField = new JTextField(20);
        emailField = new JTextField(20);
        phoneField = new JTextField(20);
        usernameField = new JTextField(20);
        passwordField = new JPasswordField(20);
        
        String[] roles = {"MANAGER", "COUNTER STAFF", "TECHNICIAN"};
        roleComboBox = new JComboBox<>(roles);
        
        Font fieldFont = new Font("Segoe UI", Font.PLAIN, 13);
        fullNameField.setFont(fieldFont);
        emailField.setFont(fieldFont);
        phoneField.setFont(fieldFont);
        usernameField.setFont(fieldFont);
        passwordField.setFont(fieldFont);
        roleComboBox.setFont(fieldFont);
    }
    
    protected void populateFields() {
        if (existingUser != null) {
            fullNameField.setText(existingUser.getFullName());
            emailField.setText(existingUser.getEmail());
            phoneField.setText(existingUser.getPhone());
            usernameField.setText(existingUser.getUsername());
            passwordField.setText(existingUser.getPassword());
            
            String roleDisplay = existingUser.getRoleDisplayName();
            if (roleDisplay.equals("Manager")) {
                roleComboBox.setSelectedItem("MANAGER");
            } else if (roleDisplay.equals("Counter Staff")) {
                roleComboBox.setSelectedItem("COUNTER STAFF");
            } else if (roleDisplay.equals("Technician")) {
                roleComboBox.setSelectedItem("TECHNICIAN");
            }
            
            // Make username field non-editable in edit mode
            usernameField.setEditable(false);
            usernameField.setBackground(new Color(248, 248, 248));
        }
    }
    
    protected void setupLayout() {
        JPanel mainPanel = new JPanel(new BorderLayout());
        mainPanel.setBackground(NAVY_BLUE);

        JPanel cardPanel = new JPanel();
        cardPanel.setLayout(new BoxLayout(cardPanel, BoxLayout.Y_AXIS));
        cardPanel.setBackground(Color.WHITE);
        cardPanel.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(BORDER_LIGHT, 2),
            BorderFactory.createLineBorder(BORDER_DARK, 2)
        ));

        // ===== HEADER =====
        JPanel headerContainer = new JPanel(new BorderLayout());

        JPanel dialogHeader = new JPanel(new BorderLayout());
        dialogHeader.setBackground(NAVY_BLUE);
        dialogHeader.setBorder(BorderFactory.createEmptyBorder(18, 25, 18, 25));

        JLabel headerTitle;
        if ("EDIT".equals(mode)) {
            headerTitle = new JLabel("Edit Staff Information");
        } else {
            headerTitle = new JLabel("Register New Staff");
        }
        headerTitle.setFont(new Font("Segoe UI", Font.BOLD, 16));
        headerTitle.setForeground(Color.WHITE);
        dialogHeader.add(headerTitle, BorderLayout.WEST);

        headerContainer.add(dialogHeader, BorderLayout.CENTER);

        JPanel yellowLine = new JPanel();
        yellowLine.setBackground(YELLOW);
        yellowLine.setPreferredSize(new Dimension(500, 4));
        headerContainer.add(yellowLine, BorderLayout.SOUTH);

        cardPanel.add(headerContainer);

        // ===== FORM PANEL =====
        JPanel formPanel = new JPanel(new GridBagLayout());
        formPanel.setBackground(Color.WHITE);
        formPanel.setBorder(BorderFactory.createEmptyBorder(35, 50, 35, 50));

        GridBagConstraints gbc = new GridBagConstraints();
        gbc.fill = GridBagConstraints.HORIZONTAL;
        gbc.insets = new Insets(10, 10, 10, 10);

        styleTextField(fullNameField);
        styleTextField(emailField);
        styleTextField(phoneField);
        styleTextField(usernameField);
        stylePasswordField(passwordField);
        styleComboBox(roleComboBox);

        // Full Name
        gbc.gridx = 0; gbc.gridy = 0;
        formPanel.add(createLabel("Full Name:"), gbc);
        gbc.gridx = 1;
        formPanel.add(fullNameField, gbc);

        // Email
        gbc.gridx = 0; gbc.gridy = 1;
        formPanel.add(createLabel("Email:"), gbc);
        gbc.gridx = 1;
        formPanel.add(emailField, gbc);

        // Phone
        gbc.gridx = 0; gbc.gridy = 2;
        formPanel.add(createLabel("Phone:"), gbc);
        gbc.gridx = 1;
        formPanel.add(phoneField, gbc);

        // Username
        gbc.gridx = 0; gbc.gridy = 3;
        formPanel.add(createLabel("Username:"), gbc);
        gbc.gridx = 1;
        formPanel.add(usernameField, gbc);

        // Password
        gbc.gridx = 0; gbc.gridy = 4;
        formPanel.add(createLabel("Password:"), gbc);
        gbc.gridx = 1;
        formPanel.add(passwordField, gbc);

        // Role
        gbc.gridx = 0; gbc.gridy = 5;
        formPanel.add(createLabel("Role:"), gbc);
        gbc.gridx = 1;
        formPanel.add(roleComboBox, gbc);

        cardPanel.add(formPanel);

        // ===== BUTTON PANEL =====
        JPanel buttonPanel = new JPanel(new FlowLayout(FlowLayout.RIGHT, 15, 20));
        buttonPanel.setBackground(Color.WHITE);
        buttonPanel.setBorder(BorderFactory.createMatteBorder(1, 0, 0, 0, new Color(230, 230, 230)));

        JButton actionButton;
        if ("EDIT".equals(mode)) {
            actionButton = createDialogButton("UPDATE", new Color(34, 197, 94));
        } else {
            actionButton = createDialogButton("REGISTER", new Color(59, 130, 246));
        }
        actionButton.addActionListener(e -> handleSubmit());

        JButton cancelButton = createDialogButton("CANCEL", new Color(100, 100, 100));
        cancelButton.addActionListener(e -> dispose());

        buttonPanel.add(actionButton);
        buttonPanel.add(cancelButton);

        cardPanel.add(buttonPanel);

        mainPanel.add(cardPanel, BorderLayout.CENTER);
        add(mainPanel);
    }
    
    protected JLabel createLabel(String text) {
        JLabel label = new JLabel(text);
        label.setFont(new Font("Segoe UI", Font.BOLD, 12));
        label.setForeground(new Color(60, 60, 60));
        label.setPreferredSize(new Dimension(100, 30));
        return label;
    }
    
    protected void styleTextField(JTextField field) {
        field.setFont(new Font("Segoe UI", Font.PLAIN, 13));
        field.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(new Color(200, 200, 200), 1),
            BorderFactory.createEmptyBorder(10, 12, 10, 12)
        ));
        field.setPreferredSize(new Dimension(300, 40));
    }
    
    protected void stylePasswordField(JPasswordField field) {
        field.setFont(new Font("Segoe UI", Font.PLAIN, 13));
        field.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(new Color(200, 200, 200), 1),
            BorderFactory.createEmptyBorder(10, 12, 10, 12)
        ));
        field.setPreferredSize(new Dimension(300, 40));
    }
    
    protected void styleComboBox(JComboBox<String> combo) {
        combo.setFont(new Font("Segoe UI", Font.PLAIN, 13));
        combo.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(new Color(200, 200, 200), 1),
            BorderFactory.createEmptyBorder(10, 12, 10, 12)
        ));
        combo.setPreferredSize(new Dimension(300, 40));
        combo.setBackground(Color.WHITE);
    }
    
    protected JButton createDialogButton(String text, Color color) {
        JButton button = new JButton(text);
        button.setFont(new Font("Segoe UI", Font.BOLD, 12));
        button.setBackground(color);
        button.setForeground(Color.WHITE);
        button.setFocusPainted(false);
        button.setBorderPainted(false);
        button.setContentAreaFilled(true);
        button.setOpaque(true);
        button.setCursor(new Cursor(Cursor.HAND_CURSOR));
        button.setBorder(BorderFactory.createEmptyBorder(10, 25, 10, 25));

        button.addMouseListener(new MouseAdapter() {
            @Override
            public void mouseEntered(MouseEvent e) {
                button.setBackground(color.darker());
            }

            @Override
            public void mouseExited(MouseEvent e) {
                button.setBackground(color);
            }
        });

        return button;
    }
    
    protected void addEventHandlers() {
        passwordField.addActionListener(e -> handleSubmit());
    }
    
    protected void handleSubmit() {
        String fullName = fullNameField.getText().trim();
        String email = emailField.getText().trim();
        String phone = phoneField.getText().trim();
        String username = usernameField.getText().trim();
        String password = new String(passwordField.getPassword());
        String role = (String) roleComboBox.getSelectedItem();
        
        // Validation
        if (fullName.isEmpty() || username.isEmpty() || password.isEmpty()) {
            JOptionPane.showMessageDialog(this,
                "Please fill all required fields.",
                "Validation Error",
                JOptionPane.WARNING_MESSAGE);
            return;
        }
        
        if (password.length() < 6) {
            JOptionPane.showMessageDialog(this,
                "Password must be at least 6 characters.",
                "Validation Error",
                JOptionPane.WARNING_MESSAGE);
            return;
        }
        
        // Check if username exists (only for registration)
        if ("REGISTER".equals(mode) && userDAO.findByUsername(username) != null) {
            JOptionPane.showMessageDialog(this,
                "Username already exists. Please choose a different username.",
                "Registration Error",
                JOptionPane.ERROR_MESSAGE);
            return;
        }
        
        // Validate email format if provided
        if (!email.isEmpty() && !email.matches("^[A-Za-z0-9+_.-]+@(.+)$")) {
            JOptionPane.showMessageDialog(this,
                "Please enter a valid email address.",
                "Validation Error",
                JOptionPane.WARNING_MESSAGE);
            return;
        }
        
        // Validate phone format if provided (10-12 digits)
        if (!phone.isEmpty() && !phone.matches("\\d{10,12}")) {
            JOptionPane.showMessageDialog(this,
                "Please enter a valid phone number (10-12 digits).",
                "Validation Error",
                JOptionPane.WARNING_MESSAGE);
            return;
        }
        
        if ("EDIT".equals(mode)) {
            handleUpdate(fullName, email, phone, password, role);
        } else {
            handleRegister(fullName, email, phone, username, password, role);
        }
    }
    
    protected void handleRegister(String fullName, String email, String phone, 
                                   String username, String password, String role) {
        User newUser = null;
        String roleDisplay = "Technician";
        
        if ("MANAGER".equals(role)) {
            newUser = new Manager(null, username, password, fullName, email, phone);
            roleDisplay = "Manager";
        } else if ("COUNTER STAFF".equals(role)) {
            newUser = new CounterStaff(null, username, password, fullName, email, phone);
            roleDisplay = "Counter Staff";
        } else if ("TECHNICIAN".equals(role)) {
            newUser = new Technician(null, username, password, fullName, email, phone);
            roleDisplay = "Technician";
        }
        
        if (newUser != null && userDAO.save(newUser)) {
            JOptionPane.showMessageDialog(this,
                "Staff registered successfully!\n\nID: " + newUser.getId() + "\nRole: " + roleDisplay,
                "Success",
                JOptionPane.INFORMATION_MESSAGE);
            if (onSuccessCallback != null) {
                onSuccessCallback.run();
            }
            dispose();
        } else {
            JOptionPane.showMessageDialog(this,
                "Registration failed. Please try again.",
                "Error",
                JOptionPane.ERROR_MESSAGE);
        }
    }
    
    protected void handleUpdate(String fullName, String email, String phone, 
                                 String password, String role) {
        if (existingUser == null) return;
        
        existingUser.setFullName(fullName);
        existingUser.setEmail(email);
        existingUser.setPhone(phone);
        existingUser.setPassword(password);
        
        if (role.equals("MANAGER")) existingUser.setRole(UserRole.MANAGER);
        else if (role.equals("COUNTER STAFF")) existingUser.setRole(UserRole.COUNTER_STAFF);
        else if (role.equals("TECHNICIAN")) existingUser.setRole(UserRole.TECHNICIAN);
        
        boolean success = userDAO.update(existingUser);
        
        if (success) {
            JOptionPane.showMessageDialog(this,
                "Staff updated successfully!",
                "Success",
                JOptionPane.INFORMATION_MESSAGE);
            if (onSuccessCallback != null) {
                onSuccessCallback.run();
            }
            dispose();
        } else {
            JOptionPane.showMessageDialog(this,
                "Failed to update staff.",
                "Error",
                JOptionPane.ERROR_MESSAGE);
        }
    }
}