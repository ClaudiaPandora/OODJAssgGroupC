package ui.manager;

import dao.AppointmentDAO;
import dao.FeedbackDAO;
import dao.CommentDAO;
import dao.UserDAO;
import models.*;
import ui.common.BasePanel;

import javax.swing.*;
import java.awt.*;
import java.util.List;

public class FeedbackPanel extends BasePanel {
    
    private FeedbackDAO feedbackDAO;
    private CommentDAO commentDAO;
    private AppointmentDAO appointmentDAO;
    private UserDAO userDAO;
    private JPanel feedbackContainer;
    private JPanel commentContainer;
    private JScrollPane feedbackScrollPane;
    private JScrollPane commentScrollPane;
    
    public FeedbackPanel() {
        this.feedbackDAO = new FeedbackDAO();
        this.commentDAO = new CommentDAO();
        this.appointmentDAO = new AppointmentDAO();
        this.userDAO = new UserDAO();
        
        setLayout(new BorderLayout());
        setBackground(PANEL_BG);
        setBorder(BorderFactory.createEmptyBorder(20, 20, 20, 20));
        
        initializeComponents();
        setupLayout();
        addEventHandlers();
        loadData();
    }
    
    @Override
    protected void initializeComponents() {
        feedbackContainer = new JPanel();
        feedbackContainer.setLayout(new BoxLayout(feedbackContainer, BoxLayout.Y_AXIS));
        feedbackContainer.setBackground(Color.WHITE);
        
        commentContainer = new JPanel();
        commentContainer.setLayout(new BoxLayout(commentContainer, BoxLayout.Y_AXIS));
        commentContainer.setBackground(Color.WHITE);
        
        feedbackScrollPane = new JScrollPane(feedbackContainer);
        commentScrollPane = new JScrollPane(commentContainer);
    }
    
    @Override
    protected void setupLayout() {
        JPanel mainPanel = new JPanel();
        mainPanel.setLayout(new BoxLayout(mainPanel, BoxLayout.Y_AXIS));
        mainPanel.setBackground(PANEL_BG);
        
        // Feedback Section
        JPanel feedbackSection = new JPanel();
        feedbackSection.setLayout(new BoxLayout(feedbackSection, BoxLayout.Y_AXIS));
        feedbackSection.setBackground(PANEL_BG);
        feedbackSection.setAlignmentX(Component.LEFT_ALIGNMENT);
        
        JLabel feedbackLabel = new JLabel("Technician Feedbacks");
        feedbackLabel.setFont(new Font("Segoe UI", Font.BOLD, 22));
        feedbackLabel.setForeground(NAVY_BLUE);
        feedbackLabel.setAlignmentX(Component.LEFT_ALIGNMENT);
        feedbackSection.add(feedbackLabel);
        feedbackSection.add(Box.createVerticalStrut(10));
        
        feedbackScrollPane.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(BORDER_DARK, 2),
            BorderFactory.createLineBorder(BORDER_LIGHT, 2)
        ));
        feedbackScrollPane.setPreferredSize(new Dimension(0, 250));
        feedbackScrollPane.setMaximumSize(new Dimension(Integer.MAX_VALUE, 250));
        feedbackScrollPane.setAlignmentX(Component.LEFT_ALIGNMENT);
        feedbackScrollPane.getVerticalScrollBar().setUnitIncrement(16);
        feedbackSection.add(feedbackScrollPane);
        
        mainPanel.add(feedbackSection);
        mainPanel.add(Box.createVerticalStrut(20));
        
        // Comments Section
        JPanel commentSection = new JPanel();
        commentSection.setLayout(new BoxLayout(commentSection, BoxLayout.Y_AXIS));
        commentSection.setBackground(PANEL_BG);
        commentSection.setAlignmentX(Component.LEFT_ALIGNMENT);
        
        JLabel commentLabel = new JLabel("Customer Comments");
        commentLabel.setFont(new Font("Segoe UI", Font.BOLD, 22));
        commentLabel.setForeground(NAVY_BLUE);
        commentLabel.setAlignmentX(Component.LEFT_ALIGNMENT);
        commentSection.add(commentLabel);
        commentSection.add(Box.createVerticalStrut(10));
        
        commentScrollPane.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(BORDER_DARK, 2),
            BorderFactory.createLineBorder(BORDER_LIGHT, 2)
        ));
        commentScrollPane.setPreferredSize(new Dimension(0, 250));
        commentScrollPane.setMaximumSize(new Dimension(Integer.MAX_VALUE, 250));
        commentScrollPane.setAlignmentX(Component.LEFT_ALIGNMENT);
        commentScrollPane.getVerticalScrollBar().setUnitIncrement(16);
        commentSection.add(commentScrollPane);
        
        mainPanel.add(commentSection);
        
        JScrollPane mainScrollPane = new JScrollPane(mainPanel);
        mainScrollPane.setBorder(null);
        mainScrollPane.setVerticalScrollBarPolicy(JScrollPane.VERTICAL_SCROLLBAR_AS_NEEDED);
        mainScrollPane.getVerticalScrollBar().setUnitIncrement(16);
        add(mainScrollPane, BorderLayout.CENTER);
    }
    
    private void loadData() {
        // Clear existing content
        feedbackContainer.removeAll();
        commentContainer.removeAll();
        
        // Load feedbacks from file
        List<Feedback> feedbacks = feedbackDAO.readAll();
        
        if (feedbacks.isEmpty()) {
            JLabel emptyLabel = new JLabel("No feedbacks available.");
            emptyLabel.setFont(new Font("Segoe UI", Font.ITALIC, 12));
            emptyLabel.setForeground(new Color(150, 150, 150));
            emptyLabel.setAlignmentX(Component.CENTER_ALIGNMENT);
            emptyLabel.setBorder(BorderFactory.createEmptyBorder(20, 0, 20, 0));
            feedbackContainer.add(emptyLabel);
        } else {
            for (int i = 0; i < feedbacks.size(); i++) {
                Feedback f = feedbacks.get(i);
                feedbackContainer.add(createFeedbackEntry(f));
                
                // Add separator line between entries (except after the last one)
                if (i < feedbacks.size() - 1) {
                    JSeparator separator = new JSeparator();
                    separator.setForeground(new Color(230, 230, 230));
                    separator.setMaximumSize(new Dimension(Integer.MAX_VALUE, 1));
                    separator.setBorder(BorderFactory.createEmptyBorder(2, 0, 2, 0));
                    feedbackContainer.add(separator);
                }
            }
        }
        
        // Load comments from file
        List<Comment> comments = commentDAO.readAll();
        
        if (comments.isEmpty()) {
            JLabel emptyLabel = new JLabel("No comments available.");
            emptyLabel.setFont(new Font("Segoe UI", Font.ITALIC, 12));
            emptyLabel.setForeground(new Color(150, 150, 150));
            emptyLabel.setAlignmentX(Component.CENTER_ALIGNMENT);
            emptyLabel.setBorder(BorderFactory.createEmptyBorder(20, 0, 20, 0));
            commentContainer.add(emptyLabel);
        } else {
            for (int i = 0; i < comments.size(); i++) {
                Comment c = comments.get(i);
                commentContainer.add(createCommentEntry(c));
                
                // Add separator line between entries (except after the last one)
                if (i < comments.size() - 1) {
                    JSeparator separator = new JSeparator();
                    separator.setForeground(new Color(230, 230, 230));
                    separator.setMaximumSize(new Dimension(Integer.MAX_VALUE, 1));
                    commentContainer.add(separator);
                }
            }
        }
        
        // Refresh UI
        feedbackContainer.revalidate();
        feedbackContainer.repaint();
        commentContainer.revalidate();
        commentContainer.repaint();
    }
    
    private JPanel createFeedbackEntry(Feedback feedback) {
        JPanel entry = new JPanel();
        entry.setLayout(new BoxLayout(entry, BoxLayout.Y_AXIS));
        entry.setBackground(Color.WHITE);
        entry.setBorder(BorderFactory.createEmptyBorder(6, 12, 6, 12));
        
        // Row 1: Appointment ID and Technician Name
        JPanel headerRow = new JPanel(new BorderLayout());
        headerRow.setBackground(Color.WHITE);
        headerRow.setMaximumSize(new Dimension(Integer.MAX_VALUE, 25));
        
        Appointment appointment = appointmentDAO.findById(feedback.getAppointmentId());
        User technician = userDAO.findById(feedback.getTechnicianId());
        
        String appointmentInfo = "Job #" + feedback.getAppointmentId();
        String technicianName = technician != null ? technician.getFullName() : "Unknown Technician";
        
        JLabel leftLabel = new JLabel(appointmentInfo);
        leftLabel.setFont(new Font("Segoe UI", Font.BOLD, 11));
        leftLabel.setForeground(NAVY_BLUE);
        
        JLabel rightLabel = new JLabel("Technician: " + technicianName);
        rightLabel.setFont(new Font("Segoe UI", Font.PLAIN, 11));
        rightLabel.setForeground(new Color(100, 100, 100));
        
        headerRow.add(leftLabel, BorderLayout.WEST);
        headerRow.add(rightLabel, BorderLayout.EAST);
        
        entry.add(headerRow);
        entry.add(Box.createVerticalStrut(4));
        
        // Row 2: Feedback Content and Rating (side by side)
        JPanel contentRow = new JPanel(new BorderLayout());
        contentRow.setBackground(Color.WHITE);
        
        JTextArea contentArea = new JTextArea(feedback.getContent());
        contentArea.setFont(new Font("Segoe UI", Font.PLAIN, 12));
        contentArea.setForeground(new Color(60, 60, 60));
        contentArea.setLineWrap(true);
        contentArea.setWrapStyleWord(true);
        contentArea.setEditable(false);
        contentArea.setBackground(Color.WHITE);
        contentArea.setBorder(BorderFactory.createEmptyBorder(0, 0, 0, 0));
        contentArea.setMargin(new Insets(0, 0, 0, 0));
        
        // Rating label aligned to the right
        JLabel ratingLabel = new JLabel("Rating: " + feedback.getRating() + " / 5");
        ratingLabel.setFont(new Font("Segoe UI", Font.PLAIN, 11));
        ratingLabel.setForeground(new Color(150, 150, 150));
        
        contentRow.add(contentArea, BorderLayout.CENTER);
        contentRow.add(ratingLabel, BorderLayout.EAST);
        
        entry.add(contentRow);
        
        return entry;
    }
    
    private JPanel createCommentEntry(Comment comment) {
        JPanel entry = new JPanel();
        entry.setLayout(new BoxLayout(entry, BoxLayout.Y_AXIS));
        entry.setBackground(Color.WHITE);
        entry.setBorder(BorderFactory.createEmptyBorder(6, 12, 6, 12));
        
        // Row 1: Appointment ID and Customer Name
        JPanel headerRow = new JPanel(new BorderLayout());
        headerRow.setBackground(Color.WHITE);
        headerRow.setMaximumSize(new Dimension(Integer.MAX_VALUE, 25));
        
        Appointment appointment = appointmentDAO.findById(comment.getAppointmentId());
        User customer = userDAO.findById(comment.getCustomerId());
        
        String appointmentInfo = "Appointment #" + comment.getAppointmentId();
        String customerName = customer != null ? customer.getFullName() : "Unknown Customer";
        
        JLabel leftLabel = new JLabel(appointmentInfo);
        leftLabel.setFont(new Font("Segoe UI", Font.BOLD, 11));
        leftLabel.setForeground(NAVY_BLUE);
        
        JLabel rightLabel = new JLabel("Customer: " + customerName);
        rightLabel.setFont(new Font("Segoe UI", Font.PLAIN, 11));
        rightLabel.setForeground(new Color(100, 100, 100));
        
        headerRow.add(leftLabel, BorderLayout.WEST);
        headerRow.add(rightLabel, BorderLayout.EAST);
        
        entry.add(headerRow);
        entry.add(Box.createVerticalStrut(4));
        
        // Row 2: Comment Content
        JPanel contentRow = new JPanel(new BorderLayout());
        contentRow.setBackground(Color.WHITE);
        
        JTextArea contentArea = new JTextArea(comment.getContent());
        contentArea.setFont(new Font("Segoe UI", Font.PLAIN, 12));
        contentArea.setForeground(new Color(60, 60, 60));
        contentArea.setLineWrap(true);
        contentArea.setWrapStyleWord(true);
        contentArea.setEditable(false);
        contentArea.setBackground(Color.WHITE);
        contentArea.setBorder(BorderFactory.createEmptyBorder(0, 0, 0, 0));
        contentArea.setMargin(new Insets(0, 0, 0, 0));
        
        contentRow.add(contentArea, BorderLayout.CENTER);
        entry.add(contentRow);
        
        return entry;
    }
    
    // Method to refresh data (can be called externally if needed)
    public void refreshData() {
        loadData();
    }
    
    @Override
    protected void addEventHandlers() {
    }
}