package ui.technician;

import dao.AppointmentDAO;
import dao.FeedbackDAO;
import enums.AppointmentStatus;
import models.Appointment;
import models.Feedback;
import models.User;
import ui.common.BasePanel;

import javax.swing.*;
import javax.swing.table.DefaultTableModel;
import java.awt.*;
import java.util.List;

public class JobsPanel extends BasePanel {
    
    private User currentTechnician;
    private AppointmentDAO appointmentDAO;
    private FeedbackDAO feedbackDAO;
    private JTable jobsTable;
    private DefaultTableModel tableModel;
    private JTextArea feedbackArea;
    private JComboBox<Integer> ratingCombo;
    private String selectedJobId = null;
    
    public JobsPanel(User technician) {
        this.currentTechnician = technician;
        this.appointmentDAO = new AppointmentDAO();
        this.feedbackDAO = new FeedbackDAO();
        
        setLayout(new BorderLayout());
        setBackground(PANEL_BG);
        setBorder(BorderFactory.createEmptyBorder(20, 20, 20, 20));
        
        initializeComponents();
        setupLayout();
        addEventHandlers();
        loadJobsData();
    }
    
    @Override
    protected void initializeComponents() {
        String[] columns = {"Job ID", "Customer", "Service", "Date", "Time", "Duration", "Status"};
        tableModel = new DefaultTableModel(columns, 0) {
            @Override
            public boolean isCellEditable(int row, int column) {
                return false;
            }
        };
        jobsTable = new JTable(tableModel);
        jobsTable.setFont(new Font("Tahoma", Font.PLAIN, 12));
        jobsTable.setRowHeight(25);
        
        feedbackArea = new JTextArea(5, 40);
        feedbackArea.setFont(new Font("Tahoma", Font.PLAIN, 12));
        feedbackArea.setLineWrap(true);
        feedbackArea.setWrapStyleWord(true);
        
        ratingCombo = new JComboBox<>();
        for (int i = 1; i <= 5; i++) {
            ratingCombo.addItem(i);
        }
    }
    
    @Override
    protected void setupLayout() {
        JPanel mainPanel = new JPanel();
        mainPanel.setLayout(new BoxLayout(mainPanel, BoxLayout.Y_AXIS));
        mainPanel.setBackground(PANEL_BG);
        
        // Header
        JLabel titleLabel = new JLabel("My Assigned Jobs");
        titleLabel.setFont(new Font("Tahoma", Font.BOLD, 24));
        titleLabel.setForeground(NAVY_BLUE);
        titleLabel.setAlignmentX(Component.LEFT_ALIGNMENT);
        mainPanel.add(titleLabel);
        mainPanel.add(Box.createVerticalStrut(15));
        
        // Jobs Table
        JPanel tablePanel = new JPanel(new BorderLayout());
        tablePanel.setBackground(Color.WHITE);
        tablePanel.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(BORDER_DARK, 2),
            BorderFactory.createLineBorder(BORDER_LIGHT, 2)
        ));
        
        JScrollPane scrollPane = new JScrollPane(jobsTable);
        scrollPane.setPreferredSize(new Dimension(800, 300));
        tablePanel.add(scrollPane, BorderLayout.CENTER);
        
        mainPanel.add(tablePanel);
        mainPanel.add(Box.createVerticalStrut(20));
        
        // Feedback Section
        JPanel feedbackPanel = new JPanel();
        feedbackPanel.setLayout(new BoxLayout(feedbackPanel, BoxLayout.Y_AXIS));
        feedbackPanel.setBackground(Color.WHITE);
        feedbackPanel.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(BORDER_LIGHT, 2),
            BorderFactory.createLineBorder(BORDER_DARK, 2)
        ));
        feedbackPanel.setMaximumSize(new Dimension(800, 250));
        feedbackPanel.setAlignmentX(Component.LEFT_ALIGNMENT);
        
        JPanel feedbackHeader = new JPanel(new BorderLayout());
        feedbackHeader.setBackground(Color.WHITE);
        feedbackHeader.setBorder(BorderFactory.createEmptyBorder(15, 15, 10, 15));
        
        JLabel feedbackLabel = new JLabel("Service Feedback/Notes");
        feedbackLabel.setFont(new Font("Tahoma", Font.BOLD, 14));
        feedbackHeader.add(feedbackLabel, BorderLayout.WEST);
        
        feedbackPanel.add(feedbackHeader);
        
        JScrollPane feedbackScroll = new JScrollPane(feedbackArea);
        feedbackScroll.setBorder(BorderFactory.createEmptyBorder(0, 15, 10, 15));
        feedbackScroll.setBackground(Color.WHITE);
        feedbackPanel.add(feedbackScroll);
        
        JPanel ratingPanel = new JPanel(new FlowLayout(FlowLayout.LEFT));
        ratingPanel.setBackground(Color.WHITE);
        ratingPanel.setBorder(BorderFactory.createEmptyBorder(0, 15, 15, 15));
        
        ratingPanel.add(new JLabel("Rating:"));
        ratingPanel.add(ratingCombo);
        ratingPanel.add(new JLabel("Stars"));
        
        feedbackPanel.add(ratingPanel);
        
        JButton completeButton = new JButton("MARK AS COMPLETED");
        completeButton.setBackground(new Color(34, 197, 94));
        completeButton.setForeground(Color.WHITE);
        completeButton.setFont(new Font("Tahoma", Font.BOLD, 12));
        completeButton.setFocusPainted(false);
        completeButton.setMaximumSize(new Dimension(200, 40));
        completeButton.setAlignmentX(Component.LEFT_ALIGNMENT);
        completeButton.setBorder(BorderFactory.createEmptyBorder(0, 15, 15, 15));
        completeButton.addActionListener(e -> completeJob());
        
        feedbackPanel.add(completeButton);
        
        mainPanel.add(feedbackPanel);
        
        add(new JScrollPane(mainPanel));
    }
    
    private void loadJobsData() {
        tableModel.setRowCount(0);
        List<Appointment> appointments = appointmentDAO.findByTechnicianId(currentTechnician.getId());
        
        for (Appointment appt : appointments) {
            if (appt.getStatus() == AppointmentStatus.ASSIGNED || 
                appt.getStatus() == AppointmentStatus.COMPLETED) {
                
                models.User customer = new dao.UserDAO().findById(appt.getCustomerId());
                
                Object[] row = {
                    appt.getId(),
                    customer != null ? customer.getFullName() : "Unknown",
                    appt.getServiceType().toString(),
                    appt.getDate(),
                    appt.getStartTime(),
                    appt.getDuration() + " hrs",
                    appt.getStatus().toString()
                };
                tableModel.addRow(row);
            }
        }
    }
    
    private void completeJob() {
        int selectedRow = jobsTable.getSelectedRow();
        if (selectedRow >= 0) {
            String jobId = (String) tableModel.getValueAt(selectedRow, 0);
            String status = (String) tableModel.getValueAt(selectedRow, 6);
            
            if (!"ASSIGNED".equals(status)) {
                JOptionPane.showMessageDialog(this, "This job cannot be completed.");
                return;
            }
            
            String feedback = feedbackArea.getText().trim();
            if (feedback.isEmpty()) {
                JOptionPane.showMessageDialog(this, "Please provide feedback before completing the job.");
                return;
            }
            
            Appointment appt = appointmentDAO.findById(jobId);
            if (appt != null) {
                // Update appointment status
                appt.setStatus(AppointmentStatus.COMPLETED);
                appointmentDAO.update(appt);
                
                // Create feedback
                Feedback fb = new Feedback();
                fb.setAppointmentId(jobId);
                fb.setTechnicianId(currentTechnician.getId());
                fb.setContent(feedback);
                feedbackDAO.save(fb);
                
                loadJobsData();
                feedbackArea.setText("");
                ratingCombo.setSelectedIndex(4);
                
                JOptionPane.showMessageDialog(this, "Job marked as completed!");
            }
        } else {
            JOptionPane.showMessageDialog(this, "Please select a job to complete.");
        }
    }
    
    @Override
    protected void addEventHandlers() {
        jobsTable.getSelectionModel().addListSelectionListener(e -> {
            if (!e.getValueIsAdjusting()) {
                int selectedRow = jobsTable.getSelectedRow();
                if (selectedRow >= 0) {
                    selectedJobId = (String) tableModel.getValueAt(selectedRow, 0);
                }
            }
        });
    }
}