package dao;

import enums.UserRole;
import models.*;
import utils.FileUtils;
import utils.IDGenerator;
import java.util.*;

public class UserDAO implements FileDAO<User> {
    
    @Override
    public List<User> readAll() {
        List<User> users = new ArrayList<>();
        users.addAll(readManagers());
        users.addAll(readCounterStaff());
        users.addAll(readTechnicians());
        users.addAll(readCustomers());
        return users;
    }
    
    public List<Manager> readManagers() {
        List<String> lines = FileUtils.readLines("src/data/managers.txt");
        List<Manager> managers = new ArrayList<>();
        for (String line : lines) {
            Manager m = Manager.fromString(line);
            if (m != null) managers.add(m);
        }
        return managers;
    }
    
    public List<CounterStaff> readCounterStaff() {
        List<String> lines = FileUtils.readLines("src/data/counter_staff.txt");
        List<CounterStaff> staff = new ArrayList<>();
        for (String line : lines) {
            CounterStaff c = CounterStaff.fromString(line);
            if (c != null) staff.add(c);
        }
        return staff;
    }
    
    public List<Technician> readTechnicians() {
        List<String> lines = FileUtils.readLines("src/data/technicians.txt");
        List<Technician> techs = new ArrayList<>();
        for (String line : lines) {
            Technician t = Technician.fromString(line);
            if (t != null) techs.add(t);
        }
        return techs;
    }
    
    public List<Customer> readCustomers() {
        List<String> lines = FileUtils.readLines("src/data/customers.txt");
        List<Customer> customers = new ArrayList<>();
        for (String line : lines) {
            Customer c = Customer.fromString(line);
            if (c != null) customers.add(c);
        }
        return customers;
    }
    
    @Override
    public User findById(String id) {
        return readAll().stream()
            .filter(u -> u.getId().equals(id))
            .findFirst()
            .orElse(null);
    }
    
    public User findByUsername(String username) {
        return readAll().stream()
            .filter(u -> u.getUsername().equals(username))
            .findFirst()
            .orElse(null);
    }
    
    @Override
    public boolean save(User user) {
        List<String> lines;
        String fileName;
        
        if (user instanceof Manager) {
            fileName = "src/data/managers.txt";
            lines = FileUtils.readLines(fileName);
            user.setId(IDGenerator.generateID("M", readManagers().size()));
            lines.add(user.toString());
        } else if (user instanceof CounterStaff) {
            fileName = "src/data/counter_staff.txt";
            lines = FileUtils.readLines(fileName);
            user.setId(IDGenerator.generateID("C", readCounterStaff().size()));
            lines.add(user.toString());
        } else if (user instanceof Technician) {
            fileName = "src/data/technicians.txt";
            lines = FileUtils.readLines(fileName);
            user.setId(IDGenerator.generateID("T", readTechnicians().size()));
            lines.add(user.toString());
        } else {
            fileName = "src/data/customers.txt";
            lines = FileUtils.readLines(fileName);
            user.setId(IDGenerator.generateID("U", readCustomers().size()));
            lines.add(user.toString());
        }
        
        return FileUtils.writeLines(fileName, lines);
    }
    
    @Override
    public boolean update(User user) {
        return save(user); // For simplicity, we'll just save all
    }
    
    @Override
    public boolean delete(String id) {
        // Implementation for delete
        return false;
    }
    
    @Override
    public String getFileName() {
        return "src/data/users.txt";
    }
}