package ui.dashboard;

import dao.UserDAO;
import models.User;
import ui.common.BasePanel;

import javax.swing.*;
import java.awt.*;

public class ProfilePanel extends BasePanel {

    private User currentUser;
    private UserDAO userDAO;

    private JTextField fullNameField;
    private JTextField emailField;
    private JTextField phoneField;
    private JTextField usernameField;
    private JPasswordField passwordField;

    private JLabel nameLabel;

    public ProfilePanel(User user) {
        this.currentUser = user;
        this.userDAO = new UserDAO();

        setBackground(PANEL_BG);

        initializeComponents();
        setupLayout();
        addEventHandlers();
    }

    @Override
    protected void initializeComponents() {

        fullNameField = new JTextField(currentUser != null ? currentUser.getFullName() : "", 30);
        emailField = new JTextField(currentUser != null ? currentUser.getEmail() : "", 30);
        phoneField = new JTextField(currentUser != null ? currentUser.getPhone() : "", 30);

        usernameField = new JTextField(currentUser != null ? currentUser.getUsername() : "", 30);
        usernameField.setEditable(false);
        usernameField.setBackground(new Color(245, 245, 245));

        passwordField = new JPasswordField(currentUser != null ? currentUser.getPassword() : "", 30);

        style(fullNameField);
        style(emailField);
        style(phoneField);
        style(usernameField);
        style(passwordField);
    }

    private void style(JComponent c) {
        c.setFont(new Font("Segoe UI", Font.PLAIN, 13));
        c.setBorder(BorderFactory.createCompoundBorder(
                BorderFactory.createLineBorder(new Color(200, 200, 200)),
                BorderFactory.createEmptyBorder(10, 12, 10, 12)
        ));
        c.setPreferredSize(new Dimension(300, 40));
    }

    @Override
    protected void setupLayout() {

        setLayout(new GridBagLayout());

        GridBagConstraints root = new GridBagConstraints();
        root.gridx = 0;
        root.gridy = 0;
        root.weightx = 1;
        root.weighty = 1;
        root.anchor = GridBagConstraints.CENTER;

        // ================= CARD (FIX HEIGHT FOR SAVE VISIBILITY) =================
        JPanel card = new JPanel();
        card.setLayout(new BoxLayout(card, BoxLayout.Y_AXIS));
        card.setBackground(Color.WHITE);
        card.setBorder(BorderFactory.createLineBorder(BORDER_DARK, 2));

        // 🔥 FIX: taller card so SAVE never gets cut
        card.setPreferredSize(new Dimension(550, 560));

        // ================= HEADER =================
        JPanel header = new JPanel() {
            @Override
            protected void paintComponent(Graphics g) {
                super.paintComponent(g);
                Graphics2D g2 = (Graphics2D) g;

                GradientPaint gp = new GradientPaint(
                        0, 0, NAVY_BLUE,
                        getWidth(), getHeight(),
                        new Color(0, 0, 90)
                );

                g2.setPaint(gp);
                g2.fillRect(0, 0, getWidth(), getHeight());
            }
        };

        header.setLayout(new BorderLayout());
        header.setPreferredSize(new Dimension(550, 105));
        header.setMaximumSize(new Dimension(Integer.MAX_VALUE, 105));

        // 🔥 FIX: reduce padding bottom/top (brings yellow line + name closer)
        header.setBorder(BorderFactory.createEmptyBorder(12, 30, 10, 30));

        // ================= LEFT TEXT BLOCK =================
        JPanel leftBlock = new JPanel();
        leftBlock.setLayout(new BoxLayout(leftBlock, BoxLayout.Y_AXIS));
        leftBlock.setOpaque(false);

        leftBlock.setAlignmentX(Component.LEFT_ALIGNMENT);

        JLabel title = new JLabel("My Profile");
        title.setFont(new Font("Segoe UI", Font.BOLD, 22));
        title.setForeground(Color.WHITE);
        title.setAlignmentX(Component.LEFT_ALIGNMENT);

        JLabel subtitle = new JLabel("Manage your personal information");
        subtitle.setFont(new Font("Segoe UI", Font.PLAIN, 11));
        subtitle.setForeground(new Color(220, 220, 220));
        subtitle.setAlignmentX(Component.LEFT_ALIGNMENT);

        leftBlock.add(title);
        leftBlock.add(Box.createVerticalStrut(2)); // 🔥 closer
        leftBlock.add(subtitle);

        header.add(leftBlock, BorderLayout.WEST);

        card.add(header);

        // ================= YELLOW BAR (CLOSER) =================
        JPanel bar = new JPanel();
        bar.setBackground(YELLOW);
        bar.setPreferredSize(new Dimension(550, 2));
        bar.setMaximumSize(new Dimension(Integer.MAX_VALUE, 2));

        card.add(bar);

        // ================= NAME SECTION (FIX ALIGNMENT + SPACING) =================
        JPanel info = new JPanel();
        info.setLayout(new BoxLayout(info, BoxLayout.Y_AXIS));
        info.setBackground(Color.WHITE);

        // 🔥 REDUCE GAP BETWEEN BAR AND NAME
        info.setBorder(BorderFactory.createEmptyBorder(10, 25, 5, 25));

        nameLabel = new JLabel(currentUser != null ? currentUser.getFullName() : "User");

        nameLabel.setFont(new Font("Segoe UI", Font.BOLD, 20));
        nameLabel.setForeground(NAVY_BLUE);

        // 🔥 TRUE LEFT ALIGN FIX
        nameLabel.setAlignmentX(Component.LEFT_ALIGNMENT);

        info.add(nameLabel);
        info.add(Box.createVerticalStrut(4)); // closer to role

        JPanel meta = new JPanel(new FlowLayout(FlowLayout.LEFT, 8, 0));
        meta.setBackground(Color.WHITE);

        JLabel role = new JLabel(currentUser != null ? currentUser.getRoleDisplayName() : "");
        role.setFont(new Font("Segoe UI", Font.BOLD, 10));
        role.setForeground(NAVY_BLUE);
        role.setOpaque(true);
        role.setBackground(new Color(230, 240, 255));
        role.setBorder(BorderFactory.createEmptyBorder(3, 10, 3, 10));

        JLabel id = new JLabel("ID: " + (currentUser != null ? currentUser.getId() : ""));
        id.setFont(new Font("Segoe UI", Font.PLAIN, 10));
        id.setForeground(new Color(120, 120, 120));

        meta.add(role);
        meta.add(id);

        info.add(meta);

        card.add(info);

        // 🔥 FIX: reduce gap between role/id and form
        card.add(Box.createVerticalStrut(2));

        // ================= FORM =================
        JPanel form = new JPanel(new GridBagLayout());
        form.setBackground(Color.WHITE);

        form.setBorder(BorderFactory.createEmptyBorder(5, 40, 5, 40));

        GridBagConstraints f = new GridBagConstraints();
        f.insets = new Insets(6, 8, 6, 8); // 🔥 tighter spacing
        f.fill = GridBagConstraints.HORIZONTAL;

        add(form, f, "Full Name", fullNameField, 0);
        add(form, f, "Email", emailField, 1);
        add(form, f, "Phone", phoneField, 2);
        add(form, f, "Username", usernameField, 3);
        add(form, f, "Password", passwordField, 4);

        card.add(form);

        // ================= SAVE BUTTON (FIX 3/4 ISSUE) =================
        JPanel btnPanel = new JPanel(new FlowLayout(FlowLayout.CENTER));
        btnPanel.setBackground(Color.WHITE);

        // 🔥 IMPORTANT: enough bottom space so button fully visible
        btnPanel.setBorder(BorderFactory.createEmptyBorder(20, 30, 60, 30));

        JButton save = new JButton("SAVE PROFILE CHANGES");

        save.setFont(new Font("Segoe UI", Font.BOLD, 11));
        save.setBackground(NAVY_BLUE);
        save.setForeground(Color.WHITE);

        save.setPreferredSize(new Dimension(240, 42));

        save.setFocusPainted(false);
        save.setBorderPainted(false);
        save.setCursor(new Cursor(Cursor.HAND_CURSOR));

        save.addMouseListener(new java.awt.event.MouseAdapter() {
            public void mouseEntered(java.awt.event.MouseEvent e) {
                save.setBackground(new Color(0, 0, 100));
            }

            public void mouseExited(java.awt.event.MouseEvent e) {
                save.setBackground(NAVY_BLUE);
            }
        });

        btnPanel.add(save);

        card.add(btnPanel);

        root.anchor = GridBagConstraints.CENTER;
        add(card, root);
    }

    private void add(JPanel panel, GridBagConstraints g,
                     String label, JComponent field, int row) {

        g.gridx = 0;
        g.gridy = row;
        g.weightx = 0;

        JLabel l = new JLabel(label);
        l.setFont(new Font("Segoe UI", Font.BOLD, 11));
        l.setForeground(new Color(80, 80, 80));
        l.setPreferredSize(new Dimension(100, 30));

        panel.add(l, g);

        g.gridx = 1;
        g.weightx = 1;

        panel.add(field, g);
    }

    @Override
    protected void addEventHandlers() {
    }
}