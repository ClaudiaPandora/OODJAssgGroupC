    private double getAverageRating() {
        List<Feedback> feedbacks = feedbackDAO.readAll();
        return feedbacks.isEmpty() ? 0 :
            feedbacks.stream().mapToInt(Feedback::getRating).average().orElse(0);
    }
    
    private void drawLineChart(Graphics g) {
        Graphics2D g2 = (Graphics2D) g;
        g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);

        int w = getWidth();
        int h = getHeight();

        int padding = 30;

        int[] data = {200, 300, 250, 400, 350, 500, 450};

        int max = 500;
        int stepX = (w - 2 * padding) / (data.length - 1);

        int prevX = padding;
        int prevY = h - padding - (data[0] * (h - 2 * padding) / max);

        for (int i = 1; i < data.length; i++) {
            int x = padding + i * stepX;
            int y = h - padding - (data[i] * (h - 2 * padding) / max);

            g2.setColor(NAVY_BLUE);
            g2.drawLine(prevX, prevY, x, y);

            g2.setColor(YELLOW);
            g2.fillOval(x - 4, y - 4, 8, 8);

            prevX = x;
            prevY = y;
        }
    }
    
