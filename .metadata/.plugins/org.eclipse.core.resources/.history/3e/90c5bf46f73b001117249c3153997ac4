    private void drawRatingBars(Graphics g) {
        Graphics2D g2 = (Graphics2D) g;

        int width = getWidth();
        int height = getHeight();

        int[] ratings = new int[5];

        for (Feedback f : feedbackDAO.readAll()) {
            ratings[f.getRating() - 1]++;
        }

        int padding = 30;
        int chartHeight = height - padding * 2;
        int barWidth = (width - padding * 2) / 5 - 10;

        int max = 1;
        for (int r : ratings) if (r > max) max = r;

        for (int i = 0; i < 5; i++) {
            int barHeight = (ratings[i] * chartHeight) / max;

            int x = padding + i * (barWidth + 10);
            int y = height - padding - barHeight;

            g2.setColor(YELLOW);
            g2.fillRect(x, y, barWidth, barHeight);

            g2.setColor(Color.BLACK);
            g2.drawString((i + 1) + "★", x + barWidth / 4, height - 10);
        }
    }
    
