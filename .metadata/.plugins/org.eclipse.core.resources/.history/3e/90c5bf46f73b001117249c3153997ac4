    private void drawCounterStaffBar(Graphics g) {
        Graphics2D g2 = (Graphics2D) g;

        int width = getWidth();
        int height = getHeight();

        int[] values = {10, 15, 8};

        int padding = 30;
        int chartHeight = height - padding * 2;
        int barWidth = (width - padding * 2) / values.length - 10;

        int max = 1;
        for (int v : values) if (v > max) max = v;

        Color[] colors = {NAVY_BLUE, new Color(100,149,237), new Color(0,200,120)};

        for (int i = 0; i < values.length; i++) {
            int barHeight = (values[i] * chartHeight) / max;

            int x = padding + i * (barWidth + 10);
            int y = height - padding - barHeight;

            g2.setColor(colors[i]);
            g2.fillRect(x, y, barWidth, barHeight);
        }
    }
    
