    private void drawDonutChart(Graphics g) {
        Graphics2D g2 = (Graphics2D) g;

        List<Appointment> appts = appointmentDAO.readAll();
        long normal = appts.stream().filter(a -> a.getServiceType() == ServiceType.NORMAL).count();
        long major = appts.stream().filter(a -> a.getServiceType() == ServiceType.MAJOR).count();

        int total = (int) (normal + major);
        if (total == 0) return;

        int size = 120;
        int x = 40, y = 40;

        int angle = (int) (360.0 * normal / total);

        g2.setColor(NAVY_BLUE);
        g2.fillArc(x, y, size, size, 0, angle);

        g2.setColor(YELLOW);
        g2.fillArc(x, y, size, size, angle, 360 - angle);

        // donut hole
        g2.setColor(Color.WHITE);
        g2.fillOval(x + 30, y + 30, 60, 60);
    }
    
