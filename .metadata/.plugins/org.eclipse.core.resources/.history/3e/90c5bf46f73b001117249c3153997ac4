        JPanel chart = new JPanel() {
            protected void paintComponent(Graphics g) {
                super.paintComponent(g);

                List<Customer> customers = userDAO.readCustomers();
                List<Appointment> appts = appointmentDAO.readAll();

                long returning = customers.stream()
                    .filter(c -> appts.stream()
                        .filter(a -> a.getCustomerId().equals(c.getId())).count() > 1)
                    .count();

                long total = customers.size();
                long newC = total - returning;

                int angle = total == 0 ? 0 : (int) (360.0 * returning / total);

                g.setColor(Color.BLUE);
                g.fillArc(40, 40, 120, 120, 0, angle);

                g.setColor(Color.GREEN);
                g.fillArc(40, 40, 120, 120, angle, 360 - angle);
            }
        };

        card.add(chart, BorderLayout.CENTER);
        return card;
    }

