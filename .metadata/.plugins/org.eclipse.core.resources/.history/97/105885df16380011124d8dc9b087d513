package ui.dashboard;

import enums.UserRole;
import models.User;
import ui.auth.LoginFrame;
import ui.common.BaseFrame;
import ui.common.HeaderPanel;
import ui.common.NavigationPanel;
import ui.counter.*;
import ui.customer.*;
import ui.manager.*;
import ui.technician.*;

import javax.swing.*;
import java.awt.*;
import java.awt.event.WindowAdapter;
import java.awt.event.WindowEvent;

public class DashboardFrame extends BaseFrame {
    
    private User currentUser;
    private CardLayout cardLayout;
    private JPanel contentPanel;
    
    public DashboardFrame(User user) {
        super();
        this.currentUser = user;
        
        System.out.println("DashboardFrame created for: " + user.getFullName() + " | Role: " + user.getRole());
        
        setTitle("APU-ASC Dashboard - " + user.getFullName());
        setSize(1200, 700);
        setLocationRelativeTo(null);
        setExtendedState(JFrame.MAXIMIZED_BOTH);
        
        initializeComponents();
        setupLayout();
        addEventHandlers();
        
        // Handle window closing
        addWindowListener(new WindowAdapter() {
            @Override
            public void windowClosing(WindowEvent e) {
                logout();
            }
        });
    }
    
    @Override
    protected void initializeComponents() {
        cardLayout = new CardLayout();
        contentPanel = new JPanel(cardLayout);
        contentPanel.setBackground(PANEL_BG);
    }
    
    @Override
    protected void setupLayout() {
        // Header
        HeaderPanel headerPanel = new HeaderPanel(currentUser);
        add(headerPanel, BorderLayout.NORTH);
        
        // Create menu bar
        setJMenuBar(createMenuBar());
        
        // Main split pane
        JSplitPane splitPane = new JSplitPane(JSplitPane.HORIZONTAL_SPLIT);
        splitPane.setDividerSize(1);
        splitPane.setDividerLocation(260);
        
        // Navigation panel
        NavigationPanel navPanel = new NavigationPanel(currentUser, cardLayout, contentPanel);
        splitPane.setLeftComponent(navPanel);
        
        // Content panels
        setupContentPanels();
        
        // Add right panel with padding
        JPanel rightWrapper = new JPanel(new BorderLayout());
        rightWrapper.setBackground(PANEL_BG);
        rightWrapper.add(contentPanel, BorderLayout.CENTER);
        
        splitPane.setRightComponent(rightWrapper);
        
        add(splitPane, BorderLayout.CENTER);
    }
    
    private JMenuBar createMenuBar() {
        JMenuBar menuBar = new JMenuBar();
        menuBar.setBackground(new Color(240, 240, 240));
        menuBar.setBorder(BorderFactory.createMatteBorder(0, 0, 1, 0, BORDER_DARK));
        
        JMenu accountMenu = new JMenu("Account");
        accountMenu.setFont(new Font("Tahoma", Font.PLAIN, 12));
        
        JMenuItem profileItem = new JMenuItem("Profile");
        profileItem.addActionListener(e -> cardLayout.show(contentPanel, "PROFILE"));
        
        JMenuItem logoutItem = new JMenuItem("Logout");
        logoutItem.addActionListener(e -> logout());
        
        accountMenu.add(profileItem);
        accountMenu.addSeparator();
        accountMenu.add(logoutItem);
        menuBar.add(accountMenu);
        
        return menuBar;
    }
    
    private void setupContentPanels() {
        try {
            // Common panels
            contentPanel.add(new OverviewPanel(currentUser), "OVERVIEW");
            contentPanel.add(new ProfilePanel(currentUser), "PROFILE");
            
            // Role-specific panels
            if (currentUser.getRole() == UserRole.MANAGER) {
                contentPanel.add(new StaffManagementPanel(), "STAFF");
                contentPanel.add(new PriceSettingsPanel(), "PRICES");
                contentPanel.add(new FeedbackPanel(), "FEEDBACKS");
                contentPanel.add(new ReportsPanel(), "REPORTS");
            } else if (currentUser.getRole() == UserRole.COUNTER_STAFF) {
                contentPanel.add(new CustomerManagementPanel(), "CUSTOMERS");
                contentPanel.add(new AppointmentPanel(), "APPOINTMENTS");
                contentPanel.add(new PaymentPanel(), "PAYMENTS");
            } else if (currentUser.getRole() == UserRole.TECHNICIAN) {
                contentPanel.add(new JobsPanel(currentUser), "JOBS");
            } else if (currentUser.getRole() == UserRole.CUSTOMER) {
                contentPanel.add(new HistoryPanel(currentUser), "HISTORY");
                contentPanel.add(new MyFeedbackPanel(currentUser), "MY_FEEDBACK");
            }
            
            // Show overview by default
            cardLayout.show(contentPanel, "OVERVIEW");
            
            System.out.println("Content panels setup complete for role: " + currentUser.getRole());
            
        } catch (Exception e) {
            System.err.println("Error setting up content panels: " + e.getMessage());
            e.printStackTrace();
        }
    }
    
    @Override
    protected void addEventHandlers() {
        // Event handlers if needed
    }
    
    private void logout() {
        int confirm = JOptionPane.showConfirmDialog(this, 
            "Are you sure you want to logout?", 
            "Logout", 
            JOptionPane.YES_NO_OPTION);
        
        if (confirm == JOptionPane.YES_OPTION) {
            new LoginFrame().setVisible(true);
            dispose();
        }
    }
}