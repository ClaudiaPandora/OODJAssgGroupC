// Action Cell Renderer
private class ActionCellRenderer extends DefaultTableCellRenderer {
    @Override
    public Component getTableCellRendererComponent(JTable table, Object value,
                                                   boolean isSelected, boolean hasFocus,
                                                   int row, int column) {
        JPanel panel = new JPanel(new FlowLayout(FlowLayout.CENTER, 10, 0));
        panel.setBackground(isSelected ? new Color(220, 220, 230) : Color.WHITE);
        
        JLabel editIcon = new JLabel("✎");
        editIcon.setFont(new Font("Segoe UI", Font.BOLD, 16));
        editIcon.setForeground(new Color(59, 130, 246));
        editIcon.setToolTipText("Edit");
        
        JLabel deleteIcon = new JLabel("🗑");
        deleteIcon.setFont(new Font("Segoe UI", Font.PLAIN, 16));
        deleteIcon.setForeground(new Color(220, 38, 38));
        deleteIcon.setToolTipText("Delete");
        
        panel.add(editIcon);
        panel.add(deleteIcon);
        
        return panel;
    }
}

// Action Cell Editor
private class ActionCellEditor extends DefaultCellEditor {
    private JPanel panel;
    private User currentUser;
    
    public ActionCellEditor() {
        super(new JTextField());
        
        panel = new JPanel(new FlowLayout(FlowLayout.CENTER, 10, 0));
        
        JLabel editIcon = new JLabel("✎");
        editIcon.setFont(new Font("Segoe UI", Font.BOLD, 16));
        editIcon.setForeground(new Color(59, 130, 246));
        editIcon.setCursor(new Cursor(Cursor.HAND_CURSOR));
        editIcon.setToolTipText("Edit");
        editIcon.addMouseListener(new java.awt.event.MouseAdapter() {
            @Override
            public void mouseClicked(java.awt.event.MouseEvent e) {
                if (currentUser != null) {
                    showEditStaffDialog(currentUser);
                }
                fireEditingStopped();
            }
        });
        
        JLabel deleteIcon = new JLabel("🗑");
        deleteIcon.setFont(new Font("Segoe UI", Font.PLAIN, 16));
        deleteIcon.setForeground(new Color(220, 38, 38));
        deleteIcon.setCursor(new Cursor(Cursor.HAND_CURSOR));
        deleteIcon.setToolTipText("Delete");
        deleteIcon.addMouseListener(new java.awt.event.MouseAdapter() {
            @Override
            public void mouseClicked(java.awt.event.MouseEvent e) {
                if (currentUser != null) {
                    deleteStaff(currentUser);
                }
                fireEditingStopped();
            }
        });
        
        panel.add(editIcon);
        panel.add(deleteIcon);
    }
    
    @Override
    public Component getTableCellEditorComponent(JTable table, Object value,
                                                 boolean isSelected, int row, int column) {
        currentUser = (User) value;
        panel.setBackground(isSelected ? new Color(220, 220, 230) : Color.WHITE);
        return panel;
    }
    
    @Override
    public Object getCellEditorValue() {
        return currentUser;
    }
}