package ui.common;

import models.User;
import javax.swing.*;
import java.awt.*;

public class HeaderPanel extends JPanel {
    
    private User currentUser;
    private Color NAVY_BLUE = new Color(0, 0, 128);
    private Color YELLOW = new Color(252, 202, 12);
    
    public HeaderPanel(User user) {
        this.currentUser = user;
        setBackground(NAVY_BLUE);
        setBorder(BorderFactory.createMatteBorder(0, 0, 1, 0, Color.BLACK));
        setLayout(new BorderLayout());
        setPreferredSize(new Dimension(0, 70));
        
        initializeComponents();
    }
    
    private void initializeComponents() {
        JPanel leftPanel = new JPanel(new FlowLayout(FlowLayout.LEFT, 15, 10));
        leftPanel.setOpaque(false);
        
        // Car icon (simulated with label)
        JLabel carIcon = new JLabel("🚗");
        carIcon.setFont(new Font("Segoe UI", Font.BOLD, 32));
        carIcon.setForeground(NAVY_BLUE);
        carIcon.setBackground(YELLOW);
        carIcon.setOpaque(true);
        carIcon.setBorder(BorderFactory.createEmptyBorder(5, 10, 5, 10));
        leftPanel.add(carIcon);
        
        JPanel textPanel = new JPanel();
        textPanel.setLayout(new BoxLayout(textPanel, BoxLayout.Y_AXIS));
        textPanel.setOpaque(false);
        
        JLabel titleLabel = new JLabel("APU-ASC SUPPORT SYSTEM");
        titleLabel.setFont(new Font("Tahoma", Font.BOLD, 20));
        titleLabel.setForeground(Color.WHITE);
        textPanel.add(titleLabel);
        
        JPanel userPanel = new JPanel(new FlowLayout(FlowLayout.LEFT, 5, 0));
        userPanel.setOpaque(false);
        
        JLabel welcomeLabel = new JLabel("Welcome,");
        welcomeLabel.setFont(new Font("Tahoma", Font.PLAIN, 12));
        welcomeLabel.setForeground(Color.WHITE);
        userPanel.add(welcomeLabel);
        
        JLabel nameLabel = new JLabel(currentUser.getFullName());
        nameLabel.setFont(new Font("Tahoma", Font.BOLD, 12));
        nameLabel.setForeground(Color.WHITE);
        userPanel.add(nameLabel);
        
        JLabel roleLabel = new JLabel("(" + currentUser.getRoleDisplayName() + ")");
        roleLabel.setFont(new Font("Tahoma", Font.PLAIN, 10));
        roleLabel.setForeground(YELLOW);
        userPanel.add(roleLabel);
        
        textPanel.add(userPanel);
        leftPanel.add(textPanel);
        
        add(leftPanel, BorderLayout.WEST);
    }
}