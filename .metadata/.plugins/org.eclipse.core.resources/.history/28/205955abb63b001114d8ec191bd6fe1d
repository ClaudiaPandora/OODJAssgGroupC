    private void loadHistory() {
        historyContent.removeAll();
        List<PriceHistory> historyList = historyDAO.readAllSortedByDate();
        
        if (historyList.isEmpty()) {
            JPanel emptyPanel = new JPanel(new GridBagLayout());
            emptyPanel.setBackground(Color.WHITE);
            JLabel emptyLabel = new JLabel("No price changes yet");
            emptyLabel.setFont(new Font("Segoe UI", Font.ITALIC, 12));
            emptyLabel.setForeground(new Color(150, 150, 150));
            emptyPanel.add(emptyLabel);
            historyContent.add(emptyPanel);
        } else {
            for (PriceHistory h : historyList) {
                historyContent.add(createHistoryEntry(h));
            }
        }
        
        historyContent.revalidate();
        historyContent.repaint();
    }
    
    private JPanel createHistoryEntry(PriceHistory history) {

        JPanel entry = new JPanel();
        entry.setLayout(new BoxLayout(entry, BoxLayout.Y_AXIS));
        entry.setBackground(Color.WHITE);

        // Fixed height (table-like consistency)
        entry.setMaximumSize(new Dimension(Integer.MAX_VALUE, 55));
        entry.setPreferredSize(new Dimension(0, 55));

        entry.setBorder(BorderFactory.createEmptyBorder(4, 12, 4, 12));

        // ROW 1 - Date (left) / By user (right)
        JPanel row1 = new JPanel(new BorderLayout());
        row1.setBackground(Color.WHITE);
        row1.setMaximumSize(new Dimension(Integer.MAX_VALUE, 20));

        JLabel dateLabel = new JLabel(history.getTimestamp());
        dateLabel.setFont(new Font("Segoe UI", Font.PLAIN, 10));
        dateLabel.setForeground(new Color(120, 120, 120));

        JLabel byLabel = new JLabel("by " + history.getChangedBy());
        byLabel.setFont(new Font("Segoe UI", Font.PLAIN, 10));
        byLabel.setForeground(new Color(120, 120, 120));
        byLabel.setHorizontalAlignment(SwingConstants.RIGHT);

        row1.add(dateLabel, BorderLayout.WEST);
        row1.add(byLabel, BorderLayout.EAST);

        // ROW 2 - Service (left) / Price change (right)
        JPanel row2 = new JPanel(new BorderLayout());
        row2.setBackground(Color.WHITE);
        row2.setMaximumSize(new Dimension(Integer.MAX_VALUE, 22));
        row2.setBorder(BorderFactory.createEmptyBorder(4, 0, 4, 0));
        
        JLabel serviceLabel = new JLabel(history.getServiceType() + " SERVICE");
        serviceLabel.setFont(new Font("Segoe UI", Font.BOLD, 11));
        serviceLabel.setForeground(NAVY_BLUE);

        JPanel pricePanel = new JPanel(new FlowLayout(FlowLayout.RIGHT, 5, 0));
        pricePanel.setBackground(Color.WHITE);

        JLabel oldPriceLabel = new JLabel("RM" + String.format("%.0f", history.getOldPrice()));
        oldPriceLabel.setFont(new Font("Segoe UI", Font.PLAIN, 11));
        oldPriceLabel.setForeground(new Color(150, 150, 150));

        JLabel arrowLabel = new JLabel("→");
        arrowLabel.setFont(new Font("Segoe UI", Font.PLAIN, 11));
        arrowLabel.setForeground(new Color(150, 150, 150));

        JLabel newPriceLabel = new JLabel("RM" + String.format("%.0f", history.getNewPrice()));
        newPriceLabel.setFont(new Font("Segoe UI", Font.BOLD, 12));
        newPriceLabel.setForeground(new Color(34, 197, 94));

        pricePanel.add(oldPriceLabel);
        pricePanel.add(arrowLabel);
        pricePanel.add(newPriceLabel);

        row2.add(serviceLabel, BorderLayout.WEST);
        row2.add(pricePanel, BorderLayout.EAST);

        // Bottom Divider
        JSeparator bottomLine = new JSeparator();
        bottomLine.setForeground(new Color(235, 235, 235));
        bottomLine.setMaximumSize(new Dimension(Integer.MAX_VALUE, 1));

        // Assemble Entry
        entry.add(row1);
        entry.add(row2);
        entry.add(bottomLine);

        return entry;
    }
    
    private void loadPrices() {
        Service normal = serviceDAO.findByType(ServiceType.NORMAL);
        Service major = serviceDAO.findByType(ServiceType.MAJOR);
        if (normal != null) normalPriceField.setText(String.valueOf((int)normal.getPrice()));
        if (major != null) majorPriceField.setText(String.valueOf((int)major.getPrice()));
    }
    
    private void updatePrice(ServiceType type, JTextField field) {
        try {
            double oldPrice = 0;
            Service existing = serviceDAO.findByType(type);
            if (existing != null) oldPrice = existing.getPrice();
            
            double newPrice = Double.parseDouble(field.getText());
            if (newPrice <= 0) {
                JOptionPane.showMessageDialog(this, "Price must be greater than 0.", "Invalid Price", JOptionPane.WARNING_MESSAGE);
                field.setText(String.valueOf((int)oldPrice));
                return;
            }
            
            if (newPrice == oldPrice) {
                JOptionPane.showMessageDialog(this, "Price is the same as current value.", "No Change", JOptionPane.INFORMATION_MESSAGE);
                return;
            }
            
            Service service = new Service(type, newPrice);
            serviceDAO.update(service);
            
            String changedBy = currentUser != null ? currentUser.getFullName() : "System";
            String timestamp = new SimpleDateFormat("yyyy-MM-dd HH:mm").format(new Date());
            PriceHistory history = new PriceHistory(null, type, oldPrice, newPrice, changedBy, timestamp);
            historyDAO.save(history);
            
            loadHistory();
            JOptionPane.showMessageDialog(this, type.name() + " service rate updated successfully!", "Success", JOptionPane.INFORMATION_MESSAGE);
        } catch (NumberFormatException e) {
            JOptionPane.showMessageDialog(this, "Please enter a valid price value.", "Invalid Price", JOptionPane.ERROR_MESSAGE);
            loadPrices();
        }
    }
    
    public void refreshData() {
        loadHistory();
